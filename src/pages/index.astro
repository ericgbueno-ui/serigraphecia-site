---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- NAV -->
  <header class="nav">
    <div class="nav-inner">
      <a href="/" class="logo">
        <img src="/logo.png" alt="Serigraph e Cia" class="logo-img" />
      </a>
      <div class="nav-actions">
        <a href="https://www.instagram.com/serigraphecia" target="_blank" rel="noopener" class="nav-insta" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="#orcamento" class="btn btn-primary btn-nav">Pedir orçamento</a>
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg-blob blob-1"></div>
    <div class="hero-bg-blob blob-2"></div>
    <div class="hero-bg-blob blob-3"></div>

    <div class="hero-inner">
      <div class="hero-tag">
        <span class="tag-dot"></span>
        Sacolas personalizadas · Disponível para envio para todo o Brasil
      </div>

      <h1 class="hero-title">
        A primeira coisa<br />
        que seu cliente<br />
        vê é a <em class="hero-highlight">sua sacola</em>
      </h1>

      <p class="hero-sub">
        Ela carrega a sua marca pelas ruas — ou não diz nada sobre você.
        Sacolas personalizadas para lojas e boutiques, em pequenas quantidades,
        com qualidade que o seu cliente vai notar.
      </p>

      <div class="hero-ctas">
        <a href="#orcamento" class="btn btn-primary">
          Quero minha sacola personalizada
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a class="btn btn-whatsapp js-wa-link" href="#" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.527 5.845L.057 23.882l6.198-1.625A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.893a9.866 9.866 0 01-5.031-1.378l-.361-.214-3.735.979 1.004-3.638-.235-.374A9.837 9.837 0 012.108 12C2.108 6.527 6.527 2.108 12 2.108c5.473 0 9.893 4.42 9.893 9.892 0 5.473-4.42 9.893-9.893 9.893z"/></svg>
          Falar no WhatsApp
        </a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">100<sup>+</sup></span>
          <span class="stat-label">peças mínimas</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">personalizado</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">7–14</span>
          <span class="stat-label">dias úteis</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-photo-wrap">
        <img src="/sacolas/bag.webp" alt="Sacola personalizada Bag Store" class="hero-photo" />
        <div class="hero-photo-badge">Bag Store</div>
        <div class="hero-photo-glow"></div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="trust-inner">
      <div class="trust-item">
        <span class="trust-num">40 anos</span>
        <span class="trust-label">de história</span>
      </div>
      <div class="trust-sep"></div>
      <div class="trust-item">
        <span class="trust-num">+1.000</span>
        <span class="trust-label">lojas atendidas</span>
      </div>
      <div class="trust-sep"></div>
      <div class="trust-item">
        <span class="trust-num">+50 mil</span>
        <span class="trust-label">sacolas produzidas</span>
      </div>
      <div class="trust-sep"></div>
      <div class="trust-item">
        <span class="trust-num">🇧🇷 Brasil todo</span>
        <span class="trust-label">disponível para envio</span>
      </div>
      <div class="trust-sep"></div>
      <div class="trust-item">
        <span class="trust-num">5★</span>
        <span class="trust-label">avaliação média</span>
      </div>
    </div>
  </div>

  <!-- DIFERENCIAIS -->
  <section class="features">
    <div class="features-inner">
      <div class="section-header">
        <h2 class="section-title">Por que a <em>Serigraph e Cia</em>?</h2>
        <p class="section-sub">Porque sua boutique merece embalagem à altura do que você vende.</p>
      </div>
      <div class="showcase-video">
        <video src="/videos/toda-linda.mp4" controls muted loop playsinline preload="metadata"></video>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon" style="background: var(--pink)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Pequenas quantidades</h3>
          <p>Atendemos desde <strong>100 unidades</strong>. Sem estoque encalhado, sem desperdício. Ideal para boutiques e lançamentos de coleção.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background: var(--yellow)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Disponível em até 14 dias</h3>
          <p>Aprovação do layout em até <strong>24h</strong>. Produção e envio em até 14 dias úteis (frete por conta do cliente).</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background: var(--cyan)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3>Sua identidade, do zero</h3>
          <p>Sua logo, sua cor, seu formato. Te ajudamos a criar se precisar. Cada detalhe pensado para refletir <strong>a sua marca</strong>.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background: var(--purple)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>Material que dura</h3>
          <p>Impressão resistente, sacola firme. Seu cliente usa, reusa e — de brinde — <strong>anuncia sua loja</strong> por onde passa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DEPOIMENTOS -->
  <section class="testimonials">
    <div class="testimonials-inner">
      <h2 class="section-title">O que dizem as lojas <em>que já pediram</em></h2>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="stars">★★★★★</div>
          <p>"A sacola ficou incrível. Meus clientes sempre comentam quando saem da loja. Já fiz 3 pedidos."</p>
          <div class="testimonial-author">
            <div class="author-avatar">A</div>
            <div>
              <strong>Andressa M.</strong>
              <span>Boutique Alma — Porto Alegre/RS</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card testimonial-featured">
          <div class="stars">★★★★★</div>
          <p>"Pedi 100 unidades pra testar. A qualidade foi tão boa que no mês seguinte pedi mais 300. Atendimento impecável, envio no prazo."</p>
          <div class="testimonial-author">
            <div class="author-avatar">R</div>
            <div>
              <strong>Rodrigo F.</strong>
              <span>Loja Reserva Concept — Caxias do Sul/RS</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="stars">★★★★★</div>
          <p>"O que mais gostei foi a rapidez. Aprovei o layout numa quinta e as sacolas chegaram na semana seguinte. Superou minhas expectativas."</p>
          <div class="testimonial-author">
            <div class="author-avatar">C</div>
            <div>
              <strong>Camila S.</strong>
              <span>Ateliê CS Moda — Florianópolis/SC</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GALERIA -->
  <section class="gallery">
    <div class="gallery-inner">
      <div class="section-header">
        <h2 class="section-title">Sacolas que já <em>saíram daqui</em></h2>
        <p class="section-sub">Cada uma com identidade própria. A sua pode ser a próxima.</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item gallery-item--featured">
          <img src="/sacolas/gab.webp" alt="Sacola personalizada Gab Store" loading="lazy" />
          <div class="bag-name-card">Gab Store</div>
        </div>
        <div class="gallery-item">
          <img src="/sacolas/mix.webp" alt="Sacola personalizada Loja Mix de Eletrônicos" loading="lazy" />
          <div class="bag-name-card">Mix de Eletrônicos</div>
        </div>
        <div class="gallery-item gallery-item--featured-alt">
          <img src="/sacolas/kids.webp" alt="Sacola personalizada Fashion Kids" loading="lazy" />
          <div class="bag-name-card">Fashion Kids</div>
        </div>
        <div class="gallery-item">
          <img src="/sacolas/tl.webp" alt="Sacola personalizada Toda Linda" loading="lazy" />
          <div class="bag-name-card">Toda Linda</div>
        </div>
      </div>
      <div class="gallery-cta">
        <a href="https://www.instagram.com/serigraphecia" target="_blank" rel="noopener" class="btn btn-outline">
          Ver mais no Instagram
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="orcamento" class="cta-section">
    <div class="cta-inner">
      <h2 class="section-title">Sua sacola está<br/><em>esperando por você</em></h2>
      <p class="cta-lead">Fale agora pelo WhatsApp e receba um orçamento personalizado em até 1 hora.</p>

      <ul class="value-list">
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Orçamento sem compromisso
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Layout incluso no pedido
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Ajustes ilimitados até aprovar
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Disponível para envio em até 14 dias úteis (frete por conta do cliente)
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          A partir de 100 unidades
        </li>
      </ul>

      <div class="urgency-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        Produção em alta demanda — antecipe o seu pedido e garanta o melhor prazo de entrega
      </div>

      <a href="#" class="btn btn-whatsapp btn-lg js-wa-link" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.527 5.845L.057 23.882l6.198-1.625A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.893a9.866 9.866 0 01-5.031-1.378l-.361-.214-3.735.979 1.004-3.638-.235-.374A9.837 9.837 0 012.108 12C2.108 6.527 6.527 2.108 12 2.108c5.473 0 9.893 4.42 9.893 9.892 0 5.473-4.42 9.893-9.893 9.893z"/></svg>
        Pedir meu orçamento pelo WhatsApp
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <img src="/logo.png" alt="Serigraph e Cia" class="footer-logo-img" />
      <p>© 2025 Serigraph e Cia · A sacola que conta a história da sua marca</p>
      <div class="footer-links">
        <a class="js-wa-link footer-wa" href="#" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.527 5.845L.057 23.882l6.198-1.625A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.893a9.866 9.866 0 01-5.031-1.378l-.361-.214-3.735.979 1.004-3.638-.235-.374A9.837 9.837 0 012.108 12C2.108 6.527 6.527 2.108 12 2.108c5.473 0 9.893 4.42 9.893 9.892 0 5.473-4.42 9.893-9.893 9.893z"/></svg>
          WhatsApp
        </a>
        <a href="https://www.instagram.com/serigraphecia" target="_blank" rel="noopener" class="footer-insta">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          Instagram
        </a>
        <a href="/admin" class="footer-admin">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Admin
        </a>
        <a href="/representante" class="footer-admin">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Representante
        </a>
      </div>
    </div>
    <div class="footer-assinatura">
      Site produzido por
      <a href="https://www.instagram.com/eric.bueno.arquiteto.de.sonhos" target="_blank" rel="noopener">
        @eric.bueno.arquiteto.de.sonhos
      </a>
    </div>
  </footer>

  <a href="#" class="floating-wa-btn js-wa-link" target="_blank" rel="noopener" aria-label="Falar no WhatsApp">
    <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.527 5.845L.057 23.882l6.198-1.625A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.893a9.866 9.866 0 01-5.031-1.378l-.361-.214-3.735.979 1.004-3.638-.235-.374A9.837 9.837 0 012.108 12C2.108 6.527 6.527 2.108 12 2.108c5.473 0 9.893 4.42 9.893 9.892 0 5.473-4.42 9.893-9.893 9.893z"/></svg>
  </a>

  <script>
    const WA = '5551843971' + '76'; // +55 51 8439-7176
    const waBase = 'https://wa.me/' + WA;
    const waMsg  = encodeURIComponent('✨ Olá! Vim pelo site da Serigraph e Cia.\n\nEstou buscando sacolas com acabamento premium para a minha loja e gostaria de solicitar um orçamento exclusivo.');

    document.querySelectorAll('.js-wa-link').forEach((el) => {
      (el as HTMLAnchorElement).href = waBase + '?text=' + waMsg;
    });
  </script>
</Layout>

<style>
  /* ─── NAV ─── */
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.1rem 2rem;
    background: rgba(13,13,13,0.88);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-actions { display: flex; align-items: center; gap: 1rem; }
  .nav-insta {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }
  .nav-insta:hover { color: var(--pink); }

  /* ─── LOGO ─── */
  .logo { display: flex; align-items: center; text-decoration: none; }
  .logo-img { height: 44px; width: auto; object-fit: contain; }
  .footer-logo-img { height: 52px; width: auto; object-fit: contain; }

  /* ─── BUTTONS ─── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    border-radius: 100px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-nav   { padding: 0.6rem 1.2rem; font-size: 0.88rem; }
  .btn-lg    { padding: 1rem 1.6rem; font-size: 1.05rem; }

  .btn-primary {
    background: var(--pink);
    color: var(--white);
    box-shadow: 0 0 22px rgba(255,45,120,0.4);
  }
  .btn-primary:hover { box-shadow: 0 0 36px rgba(255,45,120,0.6); }

  .btn-whatsapp {
    background: #25D366;
    color: var(--white);
    box-shadow: 0 0 18px rgba(37,211,102,0.3);
  }
