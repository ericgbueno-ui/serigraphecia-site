export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { prisma } from "../../lib/prisma";

const url = new URL(Astro.request.url);
const selectedMonth = url.searchParams.get("month") ?? (() => {
  const now = new Date();
  return `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}`;
})();

const [yearStr, monthStr] = selectedMonth.split("-");
const year = parseInt(yearStr);
const month = parseInt(monthStr) - 1;
const startOfMonth = new Date(Date.UTC(year, month, 1));
const endOfMonth = new Date(Date.UTC(year, month + 1, 1));

const pedidos = await prisma.pedido.findMany({
  where: { createdAt: { gte: startOfMonth, lt: endOfMonth } },
  orderBy: { createdAt: "desc" },
  take: 100,
  select: {
    id: true,
    numeroPedido: true,
    createdAt: true,
    status: true,
    totalCents: true,
    payMethod: true,
    affiliateCode: true,
    remainderCents: true,
    tipoProduto: true,
    quantidade: true,
    customer: { select: { name: true, phone: true } },
  },
});

function brl(cents: number) {
  return (cents / 100).toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
}
function fmtDate(d: Date | null) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("pt-BR", { day: "2-digit", month: "2-digit", year: "numeric" });
}
function statusBadge(s: string) {
  if (s === "CONFIRMED") return { label: "Confirmado", color: "#3ecf8e", bg: "rgba(62,207,142,0.1)", border: "rgba(62,207,142,0.25)" };
  if (s === "CANCELLED") return { label: "Cancelado", color: "#f87171", bg: "rgba(248,113,113,0.1)", border: "rgba(248,113,113,0.25)" };
  return { label: "Pendente", color: "#c9a84c", bg: "rgba(201,168,76,0.1)", border: "rgba(201,168,76,0.3)" };
}

const confirmados = pedidos.filter((p) => p.status === "CONFIRMED");
const faturamento = confirmados.reduce((s, p) => s + p.totalCents, 0);

const monthLabel = new Date(year, month).toLocaleDateString("pt-BR", { month: "long", year: "numeric" });
