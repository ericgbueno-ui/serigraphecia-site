---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { prisma } from "../../lib/prisma";

const representantes = await prisma.representante.findMany({
  where: { active: true },
  select: { id: true, name: true, code: true },
  orderBy: { name: "asc" },
});

const tabelaPrecos = await prisma.tabelaPreco.findMany({
  where: { ativo: true },
  orderBy: [{ tipo: "asc" }, { qtdMin: "asc" }],
  select: { tipo: true, qtdMin: true, qtdMax: true, precoUnitario: true },
});
---

<AdminLayout title="Novo Pedido | Admin" currentPath="/admin/nova-reserva">
  <div style="padding:32px 40px;">
    <div style="max-width:900px;">
      <div style="margin-bottom:28px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--muted);margin-bottom:6px;">Admin · Produção</p>
        <h1 style="font-size:22px;font-weight:700;">＋ Novo Pedido</h1>
        <p style="font-size:13px;color:var(--muted);margin-top:4px;">Registre um pedido de sacolas manualmente. Um pedido pode ter quantos produtos você quiser.</p>
      </div>

      <form action="/api/admin/nova-reserva" method="POST" style="display:flex;flex-direction:column;gap:24px;">

        <!-- CLIENTE -->
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;">
          <h2 style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--gold);">Cliente</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Nome de contato *</label>
              <input name="name" required placeholder="Ex: Ana Silva" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Nome da loja</label>
              <input name="nomeLoja" placeholder="Ex: Boutique Alma" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">WhatsApp *</label>
              <input name="phone" required placeholder="5511999999999" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">E-mail</label>
              <input name="email" type="email" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Instagram</label>
              <input name="instagram" placeholder="@usuario" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
          </div>
        </div>

        <!-- ENDEREÇO -->
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;">
          <h2 style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--gold);">Endereço</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Rua</label>
              <input name="endereco" placeholder="Rua, número" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Bairro</label>
              <input name="bairro" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Cidade</label>
              <input name="cidade" placeholder="Ex: Porto Alegre / RS" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
          </div>
        </div>

        <!-- PRODUTOS (múltiplos itens no mesmo pedido) -->
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <h2 style="font-size:14px;font-weight:700;color:var(--gold);">Produtos</h2>
            <button type="button" id="btn-add-produto" style="background:rgba(201,168,76,0.12);color:var(--gold);border:1px solid rgba(201,168,76,0.35);padding:8px 16px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;">
              ➕ Adicionar Produto
            </button>
          </div>

          <datalist id="lista-tamanhos"></datalist>

          <div id="itens-container" style="display:flex;flex-direction:column;gap:16px;"></div>

          <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;">
            <p style="font-size:12px;color:var(--muted);">Total calculado a partir dos produtos acima (soma dos subtotais). Pode ajustar manualmente se precisar.</p>
            <p style="font-size:20px;font-weight:800;color:#15803d;" id="soma-total-display">R$ 0,00</p>
          </div>
        </div>

        <!-- PEDIDO (dados gerais, compartilhados por todos os produtos) -->
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;">
          <h2 style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--gold);">Pedido</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Prazo de entrega</label>
              <input name="idaDate" type="date" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div></div>
            <div style="grid-column:1/-1;">
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Observações gerais</label>
              <textarea name="idaFlightTime" rows="3" placeholder="Referências, detalhes especiais..." style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;resize:vertical;"></textarea>
            </div>
          </div>
        </div>

        <!-- FINANCEIRO -->
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;">
          <h2 style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--gold);">Financeiro</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Total (R$) *</label>
              <input id="inp-total" name="totalCents" type="number" step="0.01" required placeholder="0.00" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Sinal (R$)</label>
              <input name="depositCents" type="number" step="0.01" placeholder="0.00" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Forma de pagamento</label>
              <select name="payMethod" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
                <option value="pix">PIX</option>
                <option value="cartao">Cartão</option>
                <option value="link">Link</option>
                <option value="dinheiro">Dinheiro</option>
              </select>
            </div>
          </div>
          {representantes.length > 0 && (
            <div style="margin-top:16px;">
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Representante (opcional)</label>
              <select name="affiliateCode" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
                <option value="">Nenhum</option>
                {representantes.map((r) => <option value={r.code}>{r.name} ({r.code})</option>)}
              </select>
            </div>
          )}
        </div>

        <div style="display:flex;gap:12px;justify-content:flex-end;">
          <a href="/admin/painel" style="padding:12px 20px;border:1px solid var(--border);border-radius:10px;color:var(--muted);text-decoration:none;font-size:13px;font-weight:600;">Cancelar</a>
          <button type="submit" style="padding:12px 24px;background:var(--gold);color:#05080d;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Criar Pedido →</button>
        </div>

      </form>
    </div>
  </div>

  <script type="application/json" id="tabela-precos-data">{JSON.stringify(tabelaPrecos)}</script>
  <script>
    // ── Dados da Tabela de Valores (TabelaPreco), carregados do servidor ──
    const TABELA = JSON.parse(document.getElementById("tabela-precos-data").textContent || "[]");

    const TIPO_LABELS = {
      alca_vazada: "Alça Vazada",
      alca_fita: "Alça Fita",
      alca_camiseta: "Alça Camiseta",
      outro: "Outro",
    };

    const container = document.getElementById("itens-container");
    const btnAdd = document.getElementById("btn-add-produto");
    const inpTotalGeral = document.getElementById("inp-total");
    const somaTotalDisplay = document.getElementById("soma-total-display");
    let itemIndex = 0;

    function parseRow(p) {
      let m = p.tipo.match(/^(.*) (\d+,\d+)g (\d+x\d+)$/);
      if (m) return { ...p, base: m[1], gramatura: m[2], tamanho: m[3] };
      m = p.tipo.match(/^(.*) (\d+x\d+)$/);
      if (m) return { ...p, base: m[1], gramatura: null, tamanho: m[2] };
      return { ...p, base: p.tipo, gramatura: null, tamanho: null };
    }

    function rowsParaTipo(slug) {
      const label = TIPO_LABELS[slug];
      if (!label) return [];
      return TABELA.map(parseRow).filter((p) => p.base.toLowerCase() === label.toLowerCase());
    }

    function corMultiplicador(valorSelect) {
      let n = parseInt(valorSelect, 10);
      if (valorSelect === "personalizado") n = 2;
      if (isNaN(n)) n = 1;
      return n >= 2 ? 1.4 : 1;
    }

    function brl(v) {
      return v.toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
    }

    function criarBlocoItem(idx) {
      const div = document.createElement("div");
      div.className = "item-bloco";
      div.dataset.index = String(idx);
      div.style.cssText = "border:1px solid var(--border);border-radius:12px;padding:18px;background:rgba(20,30,45,0.02);position:relative;";
      div.innerHTML = `
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
          <p style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;">Produto ${idx + 1}</p>
          <button type="button" class="btn-remove-produto" style="background:none;border:none;color:#dc2626;font-size:12px;font-weight:600;cursor:pointer;display:none;">✕ Remover</button>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Tipo de sacola *</label>
            <select class="sel-tipo" name="itens[${idx}][tripType]" required style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
              <option value="" selected disabled>Selecione...</option>
              <option value="alca_vazada">Alça Vazada</option>
              <option value="alca_fita">Alça Fita</option>
              <option value="alca_camiseta">Alça Camiseta</option>
              <option value="outro">Outro</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Quantidade *</label>
            <input class="inp-qtd" name="itens[${idx}][passengerCount]" type="number" min="1" required placeholder="Ex: 200" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Tamanho</label>
            <input class="inp-tamanho" name="itens[${idx}][tamanho]" list="lista-tamanhos" placeholder="Ex: 30x40" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            <p class="tamanho-info" style="font-size:11px;color:var(--muted);margin-top:4px;min-height:14px;"></p>
          </div>
          <div class="bloco-gramatura" style="display:none;">
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Gramatura</label>
            <select class="sel-gramatura" name="itens[${idx}][gramatura]" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
              <option value="">Selecione...</option>
            </select>
            <p class="gramatura-info" style="font-size:11px;color:var(--muted);margin-top:4px;min-height:14px;"></p>
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Cor da sacola *</label>
            <select name="itens[${idx}][corSacola]" required style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
              <option value="Amarelo">Amarelo</option>
              <option value="Azul">Azul</option>
              <option value="Branco">Branco</option>
              <option value="Lilás">Lilás</option>
              <option value="Preto">Preto</option>
              <option value="Rosa">Rosa</option>
              <option value="Rosa Bebê">Rosa Bebê</option>
              <option value="Transparente">Transparente</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Quantidade de cores de impressão</label>
            <select class="sel-cores" name="itens[${idx}][cores]" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
              <option value="1">1 cor</option>
              <option value="2">2 cores</option>
              <option value="3">3 cores</option>
              <option value="4">4 cores</option>
              <option value="4c">4 cores (CMYK)</option>
              <option value="personalizado">Personalizado</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Cor da tinta de impressão</label>
            <input name="itens[${idx}][corImpressao]" placeholder="Ex: Preto" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
          <div style="grid-column:1/-1;">
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Observações do produto</label>
            <input name="itens[${idx}][observacoes]" placeholder="Detalhes específicos deste produto..." style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
        </div>
        <div style="margin-top:12px;display:flex;justify-content:flex-end;">
          <p class="subtotal-info" style="font-size:12px;color:var(--gold);font-weight:600;"></p>
          <input type="hidden" class="inp-subtotal" name="itens[${idx}][subtotalCents]" value="0" />
        </div>
      `;
      return div;
    }

    function atualizarGramatura(bloco) {
      const selTipo = bloco.querySelector(".sel-tipo");
      const inpTamanho = bloco.querySelector(".inp-tamanho");
      const blocoGramatura = bloco.querySelector(".bloco-gramatura");
      const selGramatura = bloco.querySelector(".sel-gramatura");
      const gramaturaInfo = bloco.querySelector(".gramatura-info");

      const rows = rowsParaTipo(selTipo.value).filter(
        (r) => !inpTamanho.value || r.tamanho === inpTamanho.value
      );
      const gramaturas = [...new Set(rows.map((r) => r.gramatura).filter(Boolean))];

      if (gramaturas.length > 1) {
        blocoGramatura.style.display = "";
        selGramatura.innerHTML =
          '<option value="">Selecione...</option>' +
          gramaturas.map((g) => `<option value="${g}">${g}g</option>`).join("");
        gramaturaInfo.textContent = "Este tamanho tem mais de uma gramatura — selecione para calcular o valor.";
      } else {
        blocoGramatura.style.display = "none";
        selGramatura.value = "";
        gramaturaInfo.textContent = "";
      }
    }

    function recomputeSubtotal(bloco) {
      const selTipo = bloco.querySelector(".sel-tipo");
      const inpQtd = bloco.querySelector(".inp-qtd");
      const inpTamanho = bloco.querySelector(".inp-tamanho");
      const selGramatura = bloco.querySelector(".sel-gramatura");
      const selCores = bloco.querySelector(".sel-cores");
      const subtotalInfo = bloco.querySelector(".subtotal-info");
      const inpSubtotal = bloco.querySelector(".inp-subtotal");

      let rows = rowsParaTipo(selTipo.value).filter(
        (r) => !inpTamanho.value || r.tamanho === inpTamanho.value
      );
      const qtd = parseInt(inpQtd.value, 10) || 0;

      const gramaturas = [...new Set(rows.map((r) => r.gramatura).filter(Boolean))];
      if (gramaturas.length > 1) {
        if (selGramatura.value) {
          rows = rows.filter((r) => r.gramatura === selGramatura.value);
        } else {
          subtotalInfo.textContent = "Selecione a gramatura acima para calcular o valor.";
          inpSubtotal.value = "0";
          recomputeSomaTotal();
          return;
        }
      }

      if (rows.length === 0 || qtd <= 0) {
        subtotalInfo.textContent = "";
        inpSubtotal.value = "0";
        recomputeSomaTotal();
        return;
      }

      const ordenadas = rows.slice().sort((a, b) => a.qtdMin - b.qtdMin);
      let faixa = ordenadas.filter((r) => r.qtdMin <= qtd).pop();
      if (!faixa) faixa = ordenadas[0];

      const mult = corMultiplicador(selCores.value);
      const totalReais = faixa.precoUnitario * qtd * mult;
      const totalCents = Math.round(totalReais * 100);

      inpSubtotal.value = String(totalCents);
      subtotalInfo.textContent = `Unit.: ${brl(faixa.precoUnitario)} · Subtotal: ${brl(totalReais)}`;
      recomputeSomaTotal();
    }

    function recomputeSomaTotal() {
      const soma = [...container.querySelectorAll(".inp-subtotal")]
        .reduce((s, el) => s + (parseInt(el.value, 10) || 0), 0);
      somaTotalDisplay.textContent = brl(soma / 100);
      inpTotalGeral.value = (soma / 100).toFixed(2);
    }

    function ligarEventos(bloco) {
      const selTipo = bloco.querySelector(".sel-tipo");
      const inpQtd = bloco.querySelector(".inp-qtd");
      const inpTamanho = bloco.querySelector(".inp-tamanho");
      const selGramatura = bloco.querySelector(".sel-gramatura");
      const selCores = bloco.querySelector(".sel-cores");
      const btnRemove = bloco.querySelector(".btn-remove-produto");

      selTipo.addEventListener("change", () => {
        const rows = rowsParaTipo(selTipo.value);
        const tamanhosUnicos = [...new Set(rows.map((r) => r.tamanho).filter(Boolean))];
        document.getElementById("lista-tamanhos").innerHTML = tamanhosUnicos.map((t) => `<option value="${t}"></option>`).join("");

        const tamanhoInfo = bloco.querySelector(".tamanho-info");
        if (rows.length === 0) {
          tamanhoInfo.textContent = "Nenhum valor cadastrado para este tipo. Cadastre em Tabela de Valores.";
          recomputeSubtotal(bloco);
          return;
        }

        const menor = rows.slice().sort((a, b) => a.qtdMin - b.qtdMin)[0];
        if (!inpTamanho.value) inpTamanho.value = menor.tamanho || "";
        if (!inpQtd.value) inpQtd.value = String(menor.qtdMin);
        tamanhoInfo.textContent = tamanhosUnicos.length ? `Tamanhos disponíveis: ${tamanhosUnicos.join(", ")}` : "";

        atualizarGramatura(bloco);
        recomputeSubtotal(bloco);
      });

      inpQtd.addEventListener("input", () => recomputeSubtotal(bloco));
      inpTamanho.addEventListener("input", () => {
        atualizarGramatura(bloco);
        recomputeSubtotal(bloco);
      });
      selGramatura.addEventListener("change", () => recomputeSubtotal(bloco));
      selCores.addEventListener("change", () => recomputeSubtotal(bloco));

      btnRemove.addEventListener("click", () => {
        bloco.remove();
        recomputeSomaTotal();
        atualizarBotoesRemover();
      });
    }

    function atualizarBotoesRemover() {
      const blocos = container.querySelectorAll(".item-bloco");
      blocos.forEach((b) => {
        const btn = b.querySelector(".btn-remove-produto");
        btn.style.display = blocos.length > 1 ? "" : "none";
      });
    }

    function adicionarProduto() {
      const bloco = criarBlocoItem(itemIndex++);
      container.appendChild(bloco);
      ligarEventos(bloco);
      atualizarBotoesRemover();
    }

    btnAdd.addEventListener("click", adicionarProduto);

    // Primeiro produto já vem pronto ao carregar a página
    adicionarProduto();
  </script>

</AdminLayout>
