---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { prisma } from "../../lib/prisma";

const representantes = await prisma.affiliate.findMany({
  where: { active: true },
  select: { id: true, name: true, code: true },
  orderBy: { name: "asc" },
});
---

<AdminLayout title="Novo Pedido | Admin" currentPath="/admin/nova-reserva">
  <div style="padding:32px 40px;">
    <div style="max-width:900px;">
      <div style="margin-bottom:28px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--muted);margin-bottom:6px;">Admin · Produção</p>
        <h1 style="font-size:22px;font-weight:700;">＋ Novo Pedido</h1>
        <p style="font-size:13px;color:var(--muted);margin-top:4px;">Registre um pedido de sacolas manualmente.</p>
      </div>

      <form action="/api/admin/nova-reserva" method="POST" style="display:flex;flex-direction:column;gap:24px;">

        <!-- CLIENTE -->
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;">
          <h2 style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--gold);">Cliente</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Nome da loja / cliente *</label>
              <input name="name" required placeholder="Ex: Boutique Alma" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">WhatsApp *</label>
              <input name="phone" required placeholder="5511999999999" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">E-mail</label>
              <input name="email" type="email" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Cidade / Estado</label>
              <input name="hotel" placeholder="Ex: Porto Alegre / RS" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
          </div>
        </div>

        <!-- PEDIDO -->
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;">
          <h2 style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--gold);">Pedido</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Tipo de sacola *</label>
              <select name="tripType" required style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
                <option value="alca_vazada">Alça Vazada</option>
                <option value="alca_fita">Alça Fita</option>
                <option value="alca_camiseta">Alça Camiseta</option>
                <option value="boca_palhaço">Boca de Palhaço</option>
                <option value="outro">Outro</option>
              </select>
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Quantidade *</label>
              <input name="passengerCount" type="number" min="50" required placeholder="Ex: 200" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Tamanho</label>
              <input name="vehicleType" placeholder="Ex: 30x40cm" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Cores de impressão</label>
              <select name="voltaDate" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
                <option value="1">1 cor</option>
                <option value="2">2 cores</option>
                <option value="3">3 cores</option>
                <option value="4">4 cores</option>
                <option value="4c">4 cores (CMYK)</option>
                <option value="personalizado">Personalizado</option>
              </select>
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Prazo de entrega</label>
              <input name="idaDate" type="date" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div style="grid-column:1/-1;">
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Detalhes / observações</label>
              <textarea name="idaFlightTime" rows="3" placeholder="Cor, impressão, referências, detalhes especiais..." style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;resize:vertical;"></textarea>
            </div>
          </div>
        </div>

        <!-- FINANCEIRO -->
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;">
          <h2 style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--gold);">Financeiro</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Total (R$) *</label>
              <input name="totalCents" type="number" step="0.01" required placeholder="0.00" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Sinal (R$)</label>
              <input name="depositCents" type="number" step="0.01" placeholder="0.00" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Forma de pagamento</label>
              <select name="payMethod" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
                <option value="pix">PIX</option>
                <option value="cartao">Cartão</option>
                <option value="boleto">Boleto</option>
                <option value="transferencia">Transferência</option>
              </select>
            </div>
          </div>
          {representantes.length > 0 && (
            <div style="margin-top:16px;">
              <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Representante (opcional)</label>
              <select name="affiliateCode" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;">
                <option value="">Nenhum</option>
                {representantes.map((r) => <option value={r.code}>{r.name} ({r.code})</option>)}
              </select>
            </div>
          )}
        </div>

        <div style="display:flex;gap:12px;justify-content:flex-end;">
          <a href="/admin/painel" style="padding:12px 20px;border:1px solid var(--border);border-radius:10px;color:var(--muted);text-decoration:none;font-size:13px;font-weight:600;">Cancelar</a>
          <button type="submit" style="padding:12px 24px;background:var(--gold);color:#05080d;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Criar Pedido →</button>
        </div>

      </form>
    </div>
  </div>
</AdminLayout>
