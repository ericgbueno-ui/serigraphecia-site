---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { prisma } from "../../lib/prisma";
import { ClientesClient } from "../../components/admin/ClientesClient";

const representantes = await prisma.representante.findMany({ select: { id: true, name: true, code: true } });
const representanteMap = new Map<string, { id: string; name: string }>();
for (const rep of representantes) {
  if (rep.code) {
    representanteMap.set(rep.code.toUpperCase(), { id: rep.id, name: rep.name });
    representanteMap.set(rep.code.toLowerCase(), { id: rep.id, name: rep.name });
  }
}

const pedidos = await prisma.pedido.findMany({
  where: { status: "CONFIRMED" },
  select: {
    id: true,
    totalCents: true,
    createdAt: true,
    tipoProduto: true,
    quantidade: true,
    affiliateCode: true,
    customer: { select: { id: true, name: true, phone: true, email: true, birthDate: true } },
  },
  orderBy: { createdAt: "desc" },
});

const customerMap = new Map<string, { customer: (typeof pedidos)[0]["customer"]; pedidos: any[]; totalCents: number }>();
for (const p of pedidos) {
  const aff = p.affiliateCode ? (representanteMap.get(p.affiliateCode) || representanteMap.get(p.affiliateCode.toLowerCase()) || representanteMap.get(p.affiliateCode.toUpperCase())) : null;
  const enriched = { ...p, affiliateName: aff?.name ?? null, affiliateId: aff?.id ?? null };
  const id = p.customer.id;
  if (!customerMap.has(id)) customerMap.set(id, { customer: p.customer, pedidos: [], totalCents: 0 });
  const entry = customerMap.get(id)!;
  entry.pedidos.push(enriched);
  entry.totalCents += p.totalCents;
}

const customers = [...customerMap.values()].map((c) => ({
  ...c,
  customer: {
    ...c.customer,
    birthDate: c.customer.birthDate ? c.customer.birthDate.toISOString() : null,
  },
  bookings: c.pedidos.map((p) => ({
    ...p,
    createdAt: p.createdAt.toISOString(),
  })),
}));
---

<AdminLayout title="Clientes | Admin">
  <div style="padding:32px 40px;max-width:1100px;">
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;">
      <a href="/admin/painel" style="color:var(--muted);font-size:13px;text-decoration:none;">← Admin</a>
      <span style="color:var(--border);">|</span>
      <div>
        <h1 style="font-size:22px;font-weight:700;margin-bottom:2px;">🤎 Clientes</h1>
        <p style="font-size:12px;color:var(--muted);">Lifetime value, classificação e histórico de pedidos.</p>
      </div>
    </div>
    <ClientesClient initialCustomers={customers as any} client:load />
  </div>
</AdminLayout>
