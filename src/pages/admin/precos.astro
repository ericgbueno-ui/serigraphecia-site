---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { prisma } from "../../lib/prisma";

const precos = await prisma.tabelaPreco.findMany({
  where: { ativo: true },
  include: { modelo: true },
  orderBy: [{ modelo: { nome: "asc" } }, { tamanho: "asc" }, { qtdMin: "asc" }],
});

// Agrupa por modelo (usa a relação quando existe; cai no texto "tipo" para linhas antigas sem modeloId)
const grupos = new Map<string, typeof precos>();
for (const p of precos) {
  const base = p.modelo?.nome ?? p.tipo.replace(/ \d+x\d+$/, "");
  if (!grupos.has(base)) grupos.set(base, []);
  grupos.get(base)!.push(p);
}

// Sub-agrupa por tamanho, e dentro de cada tamanho por gramatura (um tamanho
// pode ter mais de uma gramatura, cada uma com sua própria faixa de preços).
function porTamanho(itens: typeof precos) {
  const map = new Map<string, typeof precos>();
  for (const i of itens) {
    const tam = i.tamanho ?? i.tipo.match(/(\d+x\d+)$/)?.[1] ?? "Outro";
    if (!map.has(tam)) map.set(tam, []);
    map.get(tam)!.push(i);
  }
  return map;
}

function porGramatura(itens: typeof precos) {
  const map = new Map<string, typeof precos>();
  for (const i of itens) {
    const g = i.gramatura ?? "—";
    if (!map.has(g)) map.set(g, []);
    map.get(g)!.push(i);
  }
  return [...map.entries()].sort((a, b) => a[0].localeCompare(b[0]));
}

function brl(v: any) {
  return Number(v).toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
}

function brlTotal(preco: any, qtd: number) {
  return (Number(preco) * qtd).toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
}
---

<AdminLayout title="Tabela de Valores | Admin" currentPath="/admin/precos">
  <div style="padding:32px 40px;max-width:1100px;">
    <div class="no-print" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;gap:16px;flex-wrap:wrap;">
      <div>
        <h1 style="font-size:22px;font-weight:700;">💲 Tabela de Valores</h1>
        <p style="font-size:13px;color:var(--muted);margin-top:4px;">{precos.length} faixas · 1 cor de impressão · +40% na 2ª cor ou verso</p>
      </div>
      <button
        id="btn-imprimir-tabela"
        type="button"
        style="display:flex;align-items:center;gap:8px;background:var(--gold);color:#05080d;border:none;border-radius:10px;padding:12px 22px;font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s ease;box-shadow:0 2px 8px rgba(201,168,76,0.3);"
        onmouseover="this.style.boxShadow='0 4px 12px rgba(201,168,76,0.5)';this.style.transform='translateY(-2px)';"
        onmouseout="this.style.boxShadow='0 2px 8px rgba(201,168,76,0.3)';this.style.transform='translateY(0)';"
      >
        🖨️ Imprimir tabela
      </button>
    </div>

    <div id="print-titulo-somente-impressao" style="display:none;">
      <h1 style="font-size:20px;font-weight:700;margin-bottom:2px;">Tabela de Valores — Serigraph e Cia</h1>
      <p style="font-size:12px;color:#444;margin-bottom:20px;">{precos.length} faixas · 1 cor de impressão · +40% na 2ª cor ou verso</p>
    </div>

    {[...grupos.entries()].map(([tipo, itens], idx) => {
      const tamanhos = porTamanho(itens);
      const totalFaixas = itens.length;
      return (
        <div class="bloco-modelo" style="margin-bottom:48px;border-left:4px solid var(--gold);background:rgba(201,168,76,0.03);padding:24px;border-radius:8px;">
          <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;margin-bottom:20px;padding-bottom:16px;border-bottom:2px solid rgba(201,168,76,0.2);">
            <div>
              <h2 style="font-size:18px;font-weight:700;color:var(--gold);margin:0;">🛍️ {tipo}</h2>
              <p style="font-size:12px;color:var(--muted);margin:6px 0 0 0;">{totalFaixas} faixas de preço</p>
            </div>
            <span style="font-size:11px;font-weight:600;color:var(--muted);background:rgba(201,168,76,0.15);padding:4px 12px;border-radius:20px;">Categoria {idx + 1}</span>
          </div>

          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;">
            {[...tamanhos.entries()].map(([tam, faixasDoTamanho], tamIdx) => {
              const gramaturas = porGramatura(faixasDoTamanho);
              const temVariasGramaturas = gramaturas.length > 1;
              return gramaturas.map(([gram, faixas], gramIdx) => (
                <div class="bloco-tamanho" style="background:var(--bg-card);border:2px solid var(--border);border-radius:12px;overflow:hidden;transition:all 0.2s ease;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
                  <div style="background:linear-gradient(135deg, rgba(201,168,76,0.12) 0%, rgba(201,168,76,0.05) 100%);border-bottom:2px solid rgba(201,168,76,0.2);padding:14px 16px;">
                    <p style="font-size:14px;font-weight:700;color:var(--gold);margin:0;">
                      📏 Tamanho {tam.replace("x", " × ")} cm
                      {temVariasGramaturas && gram !== "—" && (
                        <span style="font-weight:600;color:var(--muted);font-size:12px;display:block;margin-top:4px;"> gramatura {gram}g</span>
                      )}
                    </p>
                  </div>
                  <table style="width:100%;border-collapse:collapse;font-size:12px;">
                    <thead>
                      <tr style="border-bottom:2px solid rgba(201,168,76,0.2);background:rgba(201,168,76,0.04);">
                        <th style="text-align:center;padding:12px 12px;color:var(--muted);font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;">📦 Quant.</th>
                        <th style="text-align:center;padding:12px 12px;color:var(--muted);font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;">💰 Valor Unit.</th>
                        <th style="text-align:center;padding:12px 12px;color:var(--muted);font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;">💵 Valor Total</th>
                      </tr>
                    </thead>
                    <tbody>
                      {faixas.map((f, i) => (
                        <tr style={`border-bottom:${i < faixas.length - 1 ? "1px solid rgba(20,30,45,0.045)" : "none"};background:${i % 2 === 0 ? "rgba(201,168,76,0.01)" : "transparent"};`}>
                          <td style="padding:12px 12px;text-align:center;font-weight:700;font-size:14px;color:var(--text);">
                            {f.qtdMin}
                          </td>
                          <td style="padding:12px 12px;text-align:center;color:var(--gold);font-weight:700;font-size:13px;">
                            {brl(f.precoUnitario)}
                          </td>
                          <td style="padding:12px 12px;text-align:center;color:#15803d;font-weight:800;font-size:14px;">
                            {brlTotal(f.precoUnitario, f.qtdMin)}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ));
            })}
          </div>
        </div>
      );
    })}
  </div>

  <style is:global>
    @media print {
      .admin-sidebar, .admin-topbar, .admin-overlay, .admin-hamburger, .no-print {
        display: none !important;
      }
      .admin-main {
        margin: 0 !important;
        padding: 0 !important;
      }
      #print-titulo-somente-impressao {
        display: block !important;
      }
      .bloco-modelo {
        page-break-inside: avoid;
      }
      .bloco-tamanho {
        page-break-inside: avoid;
        border: 1px solid #ccc !important;
      }
      body {
        background: #fff !important;
      }
    }
  </style>

  <script>
    function setupPrintButton() {
      const btn = document.getElementById("btn-imprimir-tabela");
      if (btn) {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          setTimeout(() => window.print(), 100);
        });
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupPrintButton);
    } else {
      setupPrintButton();
    }
  </script>
</AdminLayout>
