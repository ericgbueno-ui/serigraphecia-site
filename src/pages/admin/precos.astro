---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { prisma } from "../../lib/prisma";

const precos = await prisma.tabelaPreco.findMany({ orderBy: [{ tipo: "asc" }, { qtdMin: "asc" }] });
---
<AdminLayout title="Tabela de Valores" currentPath="/admin/precos">
  <div style="padding:32px;max-width:900px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
      <h1 style="font-size:22px;font-weight:700">Tabela de Valores</h1>
      <a href="/admin/precos/novo" style="background:var(--gold);color:#000;padding:8px 18px;border-radius:8px;font-weight:600;text-decoration:none;font-size:13px">+ Novo preço</a>
    </div>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden">
      <table style="width:100%;border-collapse:collapse;font-size:13px">
        <thead>
          <tr style="border-bottom:1px solid var(--border)">
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Tipo de Sacola</th>
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Qtd Mín</th>
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Qtd Máx</th>
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Preço Unit.</th>
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Status</th>
          </tr>
        </thead>
        <tbody>
          {precos.length === 0 && (
            <tr><td colspan="5" style="padding:32px;text-align:center;color:var(--muted)">Nenhum preço cadastrado ainda.</td></tr>
          )}
          {precos.map(p => (
            <tr style="border-bottom:1px solid var(--border)">
              <td style="padding:12px 16px;font-weight:500">{p.tipo}</td>
              <td style="padding:12px 16px">{p.qtdMin}</td>
              <td style="padding:12px 16px">{p.qtdMax ?? "—"}</td>
              <td style="padding:12px 16px;color:var(--gold)">R$ {Number(p.precoUnitario).toFixed(2)}</td>
              <td style="padding:12px 16px">
                <span style={`background:${p.ativo ? "rgba(34,197,94,0.15)" : "rgba(255,59,48,0.15)"};color:${p.ativo ? "#22c55e" : "#ff3b30"};padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600`}>
                  {p.ativo ? "Ativo" : "Inativo"}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
