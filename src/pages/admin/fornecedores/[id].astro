---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { prisma } from "../../../lib/prisma";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/fornecedores');
}

const fornecedor = await prisma.fornecedor.findUnique({
  where: { id },
});

if (!fornecedor) {
  return Astro.redirect('/admin/fornecedores');
}

// Buscar itens de estoque deste fornecedor
const itensEstoque = await prisma.estoque.findMany({
  where: {
    // Se for Alquimia ou Marfel, pega todos os produtos deles
    // Caso contrário, filtra por tipo
  },
  orderBy: [{ produto: 'asc' }, { tipo: 'asc' }, { tamanho: 'asc' }, { gramatura: 'asc' }, { cor: 'asc' }],
});

// Filtrar por fornecedor se necessário
const fornecedorNome = fornecedor.nome.toLowerCase();
const itemsFiltrados = itensEstoque.filter(item => {
  if (fornecedorNome === 'alquimia') {
    return item.tipo === 'PEAD' || item.tipo === 'PEBD';
  } else if (fornecedorNome === 'marfel') {
    return item.produto && item.produto.toLowerCase().includes('sacola') || item.produto?.toLowerCase().includes('camiseta') || item.produto?.toLowerCase().includes('saco') || item.tipo !== 'PEAD' && item.tipo !== 'PEBD';
  }
  return true;
});

// Agrupar por PRODUTO
const porProduto = itemsFiltrados.reduce((acc, item) => {
  const produtoKey = item.produto || 'Sem categoria';
  if (!acc[produtoKey]) {
    acc[produtoKey] = {};
  }

  // Dentro de cada produto, agrupar por tamanho
  const tamanhoKey = item.tamanho || 'Sem tamanho';
  if (!acc[produtoKey][tamanhoKey]) {
    acc[produtoKey][tamanhoKey] = [];
  }
  acc[produtoKey][tamanhoKey].push(item);
  return acc;
}, {} as Record<string, Record<string, typeof itemsFiltrados>>);

const produtos = Object.keys(porProduto).sort();

// Obter cores únicas
const coresUnicas = Array.from(new Set(itemsFiltrados.map(i => i.cor).filter(Boolean))) as string[];

// Mapa de cores
const mapa_cores: Record<string, { bg: string; text: string }> = {
  'Branco': { bg: '#FFFFFF', text: '#000000' },
  'Preto': { bg: '#000000', text: '#FFFFFF' },
  'Colorida': { bg: '#FF69B4', text: '#FFFFFF' },
  'Rosa Bebê': { bg: '#FFB6D9', text: '#000000' },
  'Amarela': { bg: '#FFFF00', text: '#000000' },
  'Azul Bebê': { bg: '#ADD8E6', text: '#000000' },
  'Azul Royal': { bg: '#4169E1', text: '#FFFFFF' },
  'Laranja': { bg: '#FFA500', text: '#FFFFFF' },
  'Lilás': { bg: '#DA70D6', text: '#FFFFFF' },
  'Marrom': { bg: '#8B4513', text: '#FFFFFF' },
  'Ouro': { bg: '#FFD700', text: '#000000' },
  'Prata': { bg: '#C0C0C0', text: '#000000' },
  'Rosa': { bg: '#FFC0CB', text: '#000000' },
  'Rosa Neon': { bg: '#FF10F0', text: '#FFFFFF' },
  'Roxa': { bg: '#800080', text: '#FFFFFF' },
  'Transparente': { bg: '#E8E8E8', text: '#000000' },
  'Verde Água': { bg: '#7FFFD4', text: '#000000' },
  'Verde Bandeira': { bg: '#007500', text: '#FFFFFF' },
  'Verde Limão': { bg: '#32CD32', text: '#000000' },
  'Vermelha': { bg: '#FF0000', text: '#FFFFFF' },
  'Azul': { bg: '#0000FF', text: '#FFFFFF' },
  'Cobre': { bg: '#B87333', text: '#FFFFFF' },
  'Creme': { bg: '#FFFDD0', text: '#000000' },
  'Salmão': { bg: '#FA8072', text: '#FFFFFF' },
  'Vinho': { bg: '#722F37', text: '#FFFFFF' },
  'Ouro': { bg: '#FFD700', text: '#000000' },
  'Prata': { bg: '#C0C0C0', text: '#000000' },
  'Branca': { bg: '#FFFFFF', text: '#000000' },
  'Preta': { bg: '#000000', text: '#FFFFFF' },
};
---

<AdminLayout title={`${fornecedor.nome} - Catálogo`} currentPath={`/admin/fornecedores/${id}`}>
  <div style="padding:32px;max-width:1200px">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:32px">
      <div style="flex:1">
        <h1 style="font-size:28px;font-weight:700;margin:0">{fornecedor.nome}</h1>
        <p style="color:var(--muted);margin:4px 0 0 0;font-size:13px">{fornecedor.razaoSocial}</p>
        <p style="color:var(--muted);margin:8px 0 0 0">{fornecedor.produto}</p>

        {(fornecedor.endereco || fornecedor.cep) && (
          <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;color:var(--muted)">
            📍 {fornecedor.endereco}{fornecedor.bairro ? `, ${fornecedor.bairro}` : ''}
            <br />
            {fornecedor.cidade}/{fornecedor.estado} - {fornecedor.cep}
            {fornecedor.cnpj && <><br />CNPJ: {fornecedor.cnpj.replace(/(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})/, '$1.$2.$3/$4-$5')}</>}
          </div>
        )}

        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:12px;font-size:12px">
          {fornecedor.telefone && (
            <a href={`tel:${fornecedor.telefone.replace(/\D/g, '')}`} style="color:var(--gold);text-decoration:none">
              ☎️ {fornecedor.telefone}
            </a>
          )}
          {fornecedor.whatsapp && (
            <a href={`https://wa.me/${fornecedor.whatsapp.replace(/\D/g, '')}`} target="_blank" style="color:var(--gold);text-decoration:none">
              💬 WhatsApp
            </a>
          )}
          {fornecedor.email && (
            <a href={`mailto:${fornecedor.email}`} style="color:var(--gold);text-decoration:none">
              ✉️ {fornecedor.email}
            </a>
          )}
          {fornecedor.emailAdicional && (
            <a href={`mailto:${fornecedor.emailAdicional}`} style="color:var(--gold);text-decoration:none">
              ✉️ {fornecedor.emailAdicional}
            </a>
          )}
          {fornecedor.site && (
            <a href={fornecedor.site} target="_blank" style="color:var(--gold);text-decoration:none">
              🌐 Site
            </a>
          )}
        </div>
      </div>
      <a href="/admin/fornecedores" style="background:var(--bg-card);color:var(--text);padding:8px 18px;border-radius:8px;font-weight:600;text-decoration:none;font-size:13px;border:1px solid var(--border)">← Voltar</a>
    </div>

    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:24px">
      <div style="padding:16px;border-bottom:1px solid var(--border);background:rgba(255,215,0,0.1)">
        <h3 style="margin:0;color:var(--text);font-size:14px;font-weight:600">🎨 Cores Disponíveis</h3>
      </div>
      <div style="padding:16px;display:flex;flex-wrap:wrap;gap:8px">
        {coresUnicas.map(cor => {
          const cores = mapa_cores[cor] || { bg: '#CCCCCC', text: '#000000' };
          return (
            <div style={`background:${cores.bg};color:${cores.text};padding:8px 16px;border-radius:6px;font-weight:600;font-size:12px;border:1px solid rgba(0,0,0,0.1);cursor:default`}>
              {cor}
            </div>
          );
        })}
      </div>
    </div>

    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden">
      <div style="padding:16px;border-bottom:1px solid var(--border);background:rgba(255,215,0,0.1)">
        <h3 style="margin:0;color:var(--text);font-size:14px;font-weight:600">{itemsFiltrados.length} Produtos Disponíveis</h3>
      </div>

      {produtos.map(nomeProduto => (
        <div style="border-bottom:2px solid var(--border);overflow:hidden">
          {/* CABEÇALHO DO PRODUTO */}
          <div style="padding:20px 16px;background:linear-gradient(135deg, rgba(255,215,0,0.2) 0%, rgba(255,215,0,0.05) 100%);border-bottom:2px solid var(--border)">
            <h2 style="margin:0;color:var(--gold);font-size:18px;font-weight:700;letter-spacing:0.5px">
              📦 {nomeProduto}
            </h2>
            <p style="margin:8px 0 0 0;color:var(--muted);font-size:12px">
              {Object.keys(porProduto[nomeProduto]).length} tamanhos disponíveis
            </p>
          </div>

          {/* TAMANHOS DO PRODUTO */}
          {Object.keys(porProduto[nomeProduto]).sort().map(tamanho => (
            <div style="border-bottom:1px solid var(--border);overflow:hidden">
              <div style="padding:12px 16px;background:rgba(255,255,255,0.02);font-weight:600;font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px">
                📏 {tamanho}cm
              </div>

              <table style="width:100%;border-collapse:collapse;font-size:12px">
                <thead>
                  <tr style="border-bottom:1px solid var(--border);background:rgba(255,255,255,0.01)">
                    <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Cor</th>
                    <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Gramatura</th>
                    <th style="text-align:center;padding:12px 16px;color:var(--muted);font-weight:600">Qtd/Pacote</th>
                    <th style="text-align:right;padding:12px 16px;color:var(--muted);font-weight:600">Preço/kg</th>
                    <th style="text-align:right;padding:12px 16px;color:var(--muted);font-weight:600">Custo/Milheiro</th>
                    <th style="text-align:center;padding:12px 16px;color:var(--muted);font-weight:600">Estoque</th>
                  </tr>
                </thead>
                <tbody>
                  {porProduto[nomeProduto][tamanho].map(item => (
                    <tr style="border-bottom:1px solid var(--border);transition:background 0.2s;hover{background:rgba(255,255,255,0.03)}">
                      <td style="padding:12px 16px;font-weight:500;color:var(--text)">{item.cor || "—"}</td>
                      <td style="padding:12px 16px;color:var(--muted)">{item.gramatura ? `${item.gramatura}mm` : "—"}</td>
                      <td style="padding:12px 16px;text-align:center;color:var(--text);font-weight:500">
                        {item.quantidadePacote ? `${item.quantidadePacote}` : "—"}
                      </td>
                      <td style="padding:12px 16px;text-align:right;font-weight:600;color:var(--gold)">
                        {item.precoKgCents ? `R$ ${(item.precoKgCents / 100).toFixed(2)}` : "—"}
                      </td>
                      <td style="padding:12px 16px;text-align:right;color:var(--text);font-weight:500">
                        {item.custoMilheiroCents ? `R$ ${(item.custoMilheiroCents / 100).toFixed(2)}` : "—"}
                      </td>
                      <td style="padding:12px 16px;text-align:center">
                        <span style={`background:${item.quantidade > 0 ? "rgba(34,197,94,0.15)" : "rgba(156,163,175,0.15)"};color:${item.quantidade > 0 ? "#15803d" : "#6b7280"};padding:4px 12px;border-radius:4px;font-size:11px;font-weight:600`}>
                          {item.quantidade > 0 ? `${item.quantidade} ${item.unidade}` : "Sem estoque"}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ))}
        </div>
      ))}
    </div>

    {(fornecedor.banco1 || fornecedor.banco2) && (
      <div style="margin-top:24px;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden">
        <div style="padding:16px;border-bottom:1px solid var(--border);background:rgba(255,215,0,0.1)">
          <h3 style="margin:0;color:var(--text);font-size:14px;font-weight:600">🏦 Dados Bancários</h3>
        </div>
        <div style="padding:16px">
          {fornecedor.banco1 && (
            <div style="padding:12px;background:rgba(255,255,255,0.02);border-radius:6px;margin-bottom:12px;font-size:12px">
              <div style="color:var(--muted);margin-bottom:4px">Banco</div>
              <div style="font-weight:600;color:var(--text)">{fornecedor.banco1}</div>
              <div style="color:var(--muted);font-size:11px;margin-top:8px">
                Agência <span style="color:var(--text);font-weight:600">{fornecedor.agencia1}</span> | Conta <span style="color:var(--text);font-weight:600">{fornecedor.conta1}</span>
              </div>
            </div>
          )}
          {fornecedor.banco2 && (
            <div style="padding:12px;background:rgba(255,255,255,0.02);border-radius:6px;font-size:12px">
              <div style="color:var(--muted);margin-bottom:4px">Banco</div>
              <div style="font-weight:600;color:var(--text)">{fornecedor.banco2}</div>
              <div style="color:var(--muted);font-size:11px;margin-top:8px">
                Agência <span style="color:var(--text);font-weight:600">{fornecedor.agencia2}</span> | Conta <span style="color:var(--text);font-weight:600">{fornecedor.conta2}</span>
              </div>
            </div>
          )}
        </div>
      </div>
    )}

    <div style="margin-top:24px;padding:16px;background:rgba(255,215,0,0.05);border:1px solid var(--border);border-radius:8px;font-size:12px;color:var(--muted)">
      📊 Catálogo de {fornecedor.nome} com {itemsFiltrados.length} combinações de cores, tamanhos e gramaturas disponíveis em {produtos.length} linhas de produtos.
    </div>
  </div>
</AdminLayout>

<style>
  tr:hover {
    background: rgba(255, 255, 255, 0.02);
  }
</style>
