---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { prisma } from "../../lib/prisma";

const fornecedores = await prisma.fornecedor.findMany({ orderBy: { nome: "asc" } });
---
<AdminLayout title="Fornecedores" currentPath="/admin/fornecedores">
  <div style="padding:32px;max-width:900px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
      <h1 style="font-size:22px;font-weight:700">Fornecedores</h1>
      <a href="/admin/fornecedores/novo" style="background:var(--gold);color:#000;padding:8px 18px;border-radius:8px;font-weight:600;text-decoration:none;font-size:13px">+ Novo fornecedor</a>
    </div>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden">
      <table style="width:100%;border-collapse:collapse;font-size:13px">
        <thead>
          <tr style="border-bottom:1px solid var(--border)">
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Nome</th>
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Produto</th>
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">WhatsApp</th>
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Email</th>
            <th style="text-align:left;padding:12px 16px;color:var(--muted);font-weight:600">Status</th>
          </tr>
        </thead>
        <tbody>
          {fornecedores.length === 0 && (
            <tr><td colspan="5" style="padding:32px;text-align:center;color:var(--muted)">Nenhum fornecedor cadastrado ainda.</td></tr>
          )}
          {fornecedores.map(f => (
            <tr style="border-bottom:1px solid var(--border)">
              <td style="padding:12px 16px;font-weight:500">{f.nome}</td>
              <td style="padding:12px 16px;color:var(--muted)">{f.produto ?? "—"}</td>
              <td style="padding:12px 16px">{f.whatsapp ?? "—"}</td>
              <td style="padding:12px 16px">{f.email ?? "—"}</td>
              <td style="padding:12px 16px">
                <span style={`background:${f.ativo ? "rgba(34,197,94,0.15)" : "rgba(255,59,48,0.15)"};color:${f.ativo ? "#15803d" : "#dc2626"};padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600`}>
                  {f.ativo ? "Ativo" : "Inativo"}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
