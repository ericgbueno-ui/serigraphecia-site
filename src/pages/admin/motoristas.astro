---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { prisma } from "../../lib/prisma";

const drivers = await prisma.driver.findMany({
  orderBy: { createdAt: "desc" },
});

const statusColor = (s: string) => {
  if (s === "APPROVED") return { color: "#3ecf8e", bg: "rgba(62,207,142,0.1)", border: "rgba(62,207,142,0.25)", label: "Aprovado" };
  if (s === "REJECTED") return { color: "#f87171", bg: "rgba(248,113,113,0.1)", border: "rgba(248,113,113,0.25)", label: "Rejeitado" };
  return { color: "#c9a84c", bg: "rgba(201,168,76,0.1)", border: "rgba(201,168,76,0.3)", label: "Pendente" };
};

function fmtDate(d: Date) {
  return new Date(d).toLocaleDateString("pt-BR", { day: "2-digit", month: "2-digit", year: "numeric" });
}
---

<AdminLayout title="Motoristas | Admin">
  <div style="padding:32px 40px;">
    <div style="max-width:1100px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px;">
        <div>
          <h1 style="font-size:22px;font-weight:700;margin-bottom:4px;">🚙 Motoristas / Frota</h1>
          <p style="font-size:13px;color:var(--muted);">Gerenciar motoristas parceiros e cadastros pendentes.</p>
        </div>
        <div style="display:flex;gap:8px;align-items:center;">
          <span style="font-size:13px;color:var(--muted);">{drivers.length} motoristas cadastrados</span>
        </div>
      </div>

      {drivers.length === 0 ? (
        <div style="text-align:center;padding:60px;color:var(--muted);background:var(--bg-card);border:1px solid var(--border);border-radius:14px;">
          Nenhum motorista cadastrado ainda.
        </div>
      ) : (
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;overflow:hidden;">
          <div style="display:grid;grid-template-columns:2fr 1.5fr 1fr 1fr auto;gap:12px;padding:12px 20px;border-bottom:1px solid var(--border);background:rgba(255,255,255,0.02);">
            {["Motorista", "Veículo", "Cadastro", "Tipo", "Status"].map((h) => (
              <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);">{h}</span>
            ))}
          </div>
          {drivers.map((driver, i) => {
            const sc = statusColor(driver.status);
            return (
              <div style={`display:grid;grid-template-columns:2fr 1.5fr 1fr 1fr auto;gap:12px;padding:16px 20px;align-items:center;${i < drivers.length - 1 ? "border-bottom:1px solid rgba(255,255,255,0.04);" : ""}`}>
                <div>
                  <p style="font-size:13px;font-weight:600;">{driver.name}</p>
                  <p style="font-size:11px;color:var(--muted);margin-top:2px;">📱 {driver.phone}</p>
                  {driver.pixKey && <p style="font-size:11px;color:var(--muted);">PIX: {driver.pixKey}</p>}
                </div>
                <div>
                  <p style="font-size:13px;">{driver.carModel} · {driver.carColor}</p>
                  <p style="font-size:11px;color:var(--muted);margin-top:2px;">Placa: {driver.carPlate} · {driver.carYear}</p>
                  {driver.hybridOrElectric && <p style="font-size:11px;color:#3ecf8e;">{driver.hybridOrElectric}</p>}
                </div>
                <div>
                  <p style="font-size:12px;color:var(--text);">{fmtDate(driver.createdAt)}</p>
                </div>
                <div>
                  <p style="font-size:12px;color:var(--muted);">{driver.companyType}</p>
                  {driver.cadastur && <p style="font-size:11px;color:#a78bfa;">Cadastur ✓</p>}
                </div>
                <span style={`padding:4px 10px;border-radius:100px;font-size:11px;font-weight:600;white-space:nowrap;color:${sc.color};background:${sc.bg};border:1px solid ${sc.border};`}>
                  {sc.label}
                </span>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </div>
</AdminLayout>
