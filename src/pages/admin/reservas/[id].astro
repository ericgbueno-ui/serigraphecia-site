---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { prisma } from "../../../lib/prisma";

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/reservas");

const pedido = await prisma.pedido.findUnique({
  where: { id },
  include: { customer: true, payments: true, itens: true },
});

if (!pedido) return Astro.redirect("/admin/reservas");

function brl(cents: number) {
  return (cents / 100).toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
}
function fmtDate(d: Date | null) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("pt-BR", { day: "2-digit", month: "2-digit", year: "numeric" });
}
// Formato yyyy-mm-dd para preencher <input type="date"> com o valor atual
function fmtDateInput(d: Date | null) {
  if (!d) return "";
  const dt = new Date(d);
  return dt.toISOString().slice(0, 10);
}
const statusColor = pedido.status === "CONFIRMED" ? "#15803d" : pedido.status === "CANCELLED" ? "#dc2626" : "#a9802e";
const statusLabel = pedido.status === "CONFIRMED" ? "Confirmado" : pedido.status === "CANCELLED" ? "Cancelado" : "Pendente";
---

<AdminLayout title={`Pedido ${id.slice(0, 8)} | Admin`}>
  <div style="padding:32px 40px;">
    <div style="max-width:900px;">
      <!-- Cabeçalho -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <a href="/admin/reservas" style="color:var(--muted);font-size:13px;text-decoration:none;">← Pedidos</a>
          <span style="color:var(--border);">|</span>
          <span style="font-size:11px;color:var(--muted);">{pedido.numeroPedido ?? `#${id.slice(0, 8).toUpperCase()}`}</span>
        </div>
        <span style={`padding:6px 14px;border-radius:100px;font-size:12px;font-weight:700;color:${statusColor};background:${statusColor}22;border:1px solid ${statusColor}44;`}>{statusLabel}</span>
      </div>

      <!-- Cliente -->
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;">
        <h2 style="font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;">👤 Cliente</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Nome</p>
            <p style="font-size:14px;font-weight:600;">{pedido.customer.name}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">WhatsApp</p>
            <a href={`https://wa.me/55${pedido.customer.phone}`} target="_blank" style="font-size:14px;font-weight:600;color:#15803d;text-decoration:none;">💬 {pedido.customer.phone}</a>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">E-mail</p>
            <p style="font-size:14px;">{pedido.customer.email || "—"}</p>
          </div>
        </div>
      </div>

      <!-- Pedido -->
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;">
        <h2 style="font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;">🛍️ Pedido</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Produto</p>
            <p style="font-size:14px;font-weight:600;">{pedido.tipoProduto}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Quantidade</p>
            <p style="font-size:14px;font-weight:600;">{pedido.quantidade} un</p>
          </div>
          {pedido.corProduto && (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Cor</p>
              <p style="font-size:14px;">{pedido.corProduto}</p>
            </div>
          )}
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Impressão</p>
            <p style="font-size:14px;">{pedido.lados === "dois" ? "Frente e verso" : "Um lado"} · {pedido.coresLadoA} cor(es) lado A{pedido.coresLadoB ? ` · ${pedido.coresLadoB} cor(es) lado B` : ""}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Produção</p>
            <p style="font-size:14px;">{pedido.producaoConcluida ? "✅ Concluída" : "⏳ Em produção"}</p>
          </div>
        </div>
        {pedido.internalNotes && (
          <div style="margin-top:16px;">
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Observações</p>
            <p style="font-size:13px;white-space:pre-wrap;">{pedido.internalNotes}</p>
          </div>
        )}
      </div>

      <!-- Itens do pedido (Fase 2 — suporte a múltiplos produtos) -->
      {pedido.itens.length > 0 && (
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;">
          <h2 style="font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;">📦 Itens do pedido</h2>
          <div style="display:flex;flex-direction:column;gap:8px;">
            {pedido.itens.map((item) => (
              <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);">
                <div>
                  <p style="font-size:13px;font-weight:600;">{item.nome}{item.cor ? ` · ${item.cor}` : ""}{item.tamanho ? ` · ${item.tamanho}` : ""}</p>
                  <p style="font-size:12px;color:var(--muted);">{item.quantidade} un × {brl(item.valorUnitarioCents)}</p>
                </div>
                <p style="font-size:14px;font-weight:700;">{brl(item.subtotalCents)}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Datas (Fase 2 — controle independente de prazos) -->
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;">
        <h2 style="font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;">🗓️ Datas</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:20px;">
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Data do pedido</p>
            <p style="font-size:14px;">{fmtDate(pedido.dataPedido)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Data de cadastro</p>
            <p style="font-size:14px;">{fmtDate(pedido.createdAt)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Prevista · Produção</p>
            <p style="font-size:14px;">{fmtDate(pedido.dataPrevistaProducao)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Prevista · Conclusão</p>
            <p style="font-size:14px;">{fmtDate(pedido.dataPrevistaConclusao)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Prevista · Entrega</p>
            <p style="font-size:14px;font-weight:700;color:var(--gold);">{fmtDate(pedido.dataPrevistaEntrega)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Entrega real</p>
            <p style="font-size:14px;">{fmtDate(pedido.dataEntregaReal)}</p>
          </div>
          {pedido.dataCancelamento && (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Cancelado em</p>
              <p style="font-size:14px;color:#dc2626;">{fmtDate(pedido.dataCancelamento)}</p>
              {pedido.motivoCancelamento && <p style="font-size:12px;color:var(--muted);">{pedido.motivoCancelamento}</p>}
            </div>
          )}
        </div>

        {!pedido.dataCancelamento && (
          <form action="/api/admin/pedido-datas" method="POST" style="border-top:1px solid var(--border);padding-top:16px;">
            <input type="hidden" name="pedidoId" value={pedido.id} />
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:14px;">
              <label style="font-size:11px;color:var(--muted);">
                Prevista · Produção
                <input type="date" name="dataPrevistaProducao" value={fmtDateInput(pedido.dataPrevistaProducao)}
                  style="display:block;margin-top:4px;width:100%;padding:8px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text);font-size:13px;" />
              </label>
              <label style="font-size:11px;color:var(--muted);">
                Prevista · Conclusão
                <input type="date" name="dataPrevistaConclusao" value={fmtDateInput(pedido.dataPrevistaConclusao)}
                  style="display:block;margin-top:4px;width:100%;padding:8px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text);font-size:13px;" />
              </label>
              <label style="font-size:11px;color:var(--muted);">
                Prevista · Entrega
                <input type="date" name="dataPrevistaEntrega" value={fmtDateInput(pedido.dataPrevistaEntrega)}
                  style="display:block;margin-top:4px;width:100%;padding:8px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text);font-size:13px;" />
              </label>
              <label style="font-size:11px;color:var(--muted);">
                Entrega real
                <input type="date" name="dataEntregaReal" value={fmtDateInput(pedido.dataEntregaReal)}
                  style="display:block;margin-top:4px;width:100%;padding:8px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text);font-size:13px;" />
              </label>
            </div>
            <div style="display:flex;gap:10px;align-items:center;">
              <button type="submit" style="padding:9px 16px;background:var(--gold);color:#05080d;font-weight:700;font-size:12px;border:none;border-radius:8px;cursor:pointer;">
                Salvar datas
              </button>
              <span style="font-size:11px;color:var(--muted);">Toda alteração fica registrada no histórico.</span>
            </div>
          </form>
        )}

        {!pedido.dataCancelamento && (
          <form action="/api/admin/pedido-datas" method="POST" style="border-top:1px solid var(--border);margin-top:16px;padding-top:16px;">
            <input type="hidden" name="pedidoId" value={pedido.id} />
            <input type="hidden" name="cancelar" value="1" />
            <label style="font-size:11px;color:var(--muted);display:block;margin-bottom:8px;">
              Motivo do cancelamento (obrigatório para cancelar)
              <input type="text" name="motivo" placeholder="Ex: cliente desistiu, duplicidade..."
                style="display:block;margin-top:4px;width:100%;padding:8px;border-radius:8px;border:1px solid rgba(220,38,38,0.35);background:transparent;color:var(--text);font-size:13px;" />
            </label>
            <button type="submit" style="padding:8px 14px;background:transparent;color:#dc2626;font-weight:700;font-size:12px;border:1px solid rgba(220,38,38,0.4);border-radius:8px;cursor:pointer;">
              Cancelar pedido
            </button>
          </form>
        )}
      </div>

      <!-- Financeiro -->
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;">
        <h2 style="font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;">💰 Financeiro</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Total</p>
            <p style="font-size:22px;font-weight:800;color:#15803d;">{brl(pedido.totalCents)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Já Recebido</p>
            <p style="font-size:22px;font-weight:800;color:var(--text);">{brl(pedido.totalCents - pedido.remainderCents)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">A Receber</p>
            <p style={`font-size:22px;font-weight:800;color:${pedido.remainderCents > 0 ? "#a9802e" : "var(--muted)"};`}>{brl(pedido.remainderCents)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Pagamento</p>
            <p style="font-size:14px;text-transform:uppercase;">{pedido.payMethod === "pix" ? "PIX" : pedido.payMethod === "cartao" ? "Cartão" : pedido.payMethod}</p>
          </div>
          {pedido.affiliateCode && (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Representante</p>
              <p style="font-size:14px;color:var(--gold);">👥 {pedido.affiliateCode}</p>
            </div>
          )}
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Criado em</p>
            <p style="font-size:14px;">{fmtDate(pedido.createdAt)}</p>
          </div>
        </div>
      </div>

      <!-- Ações -->
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <a href="/admin/reservas" style="padding:10px 18px;border:1px solid var(--border);color:var(--muted);border-radius:10px;text-decoration:none;font-size:13px;">← Voltar</a>
      </div>
    </div>
  </div>
</AdminLayout>
