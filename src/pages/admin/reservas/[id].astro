---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { prisma } from "../../../lib/prisma";

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/reservas");

const booking = await prisma.booking.findUnique({
  where: { id },
  include: { customer: true, passengers: true, payments: true },
});

if (!booking) return Astro.redirect("/admin/reservas");

function brl(cents: number) {
  return (cents / 100).toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
}
function fmtDate(d: Date | null) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("pt-BR", { day: "2-digit", month: "2-digit", year: "numeric" });
}
function tripLabel(t: string) {
  if (t === "so_citytour") return "Somente City Tour";
  if (t === "ida_volta") return "Chegada In + Retorno Out";
  if (t === "volta") return "Retorno Out";
  return "Chegada In";
}
const statusColor = booking.status === "CONFIRMED" ? "#3ecf8e" : booking.status === "CANCELLED" ? "#f87171" : "#c9a84c";
const statusLabel = booking.status === "CONFIRMED" ? "Confirmada" : booking.status === "CANCELLED" ? "Cancelada" : "Pendente";
---

<AdminLayout title={`Reserva ${id.slice(0, 8)} | Admin`}>
  <div style="padding:32px 40px;">
    <div style="max-width:900px;">
      <!-- Cabeçalho -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <a href="/admin/reservas" style="color:var(--muted);font-size:13px;text-decoration:none;">← Contratos</a>
          <span style="color:var(--border);">|</span>
          <span style="font-size:11px;color:var(--muted);">#{id.slice(0, 8).toUpperCase()}</span>
        </div>
        <span style={`padding:6px 14px;border-radius:100px;font-size:12px;font-weight:700;color:${statusColor};background:${statusColor}22;border:1px solid ${statusColor}44;`}>{statusLabel}</span>
      </div>

      <!-- Cliente -->
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;">
        <h2 style="font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;">👤 Cliente</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Nome</p>
            <p style="font-size:14px;font-weight:600;">{booking.customer.name}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">WhatsApp</p>
            <a href={`https://wa.me/55${booking.customer.phone}`} target="_blank" style="font-size:14px;font-weight:600;color:#3ecf8e;text-decoration:none;">💬 {booking.customer.phone}</a>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">E-mail</p>
            <p style="font-size:14px;">{booking.customer.email || "—"}</p>
          </div>
        </div>
      </div>

      <!-- Viagem -->
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;">
        <h2 style="font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;">✈️ Viagem</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Tipo</p>
            <p style="font-size:14px;font-weight:600;">{tripLabel(booking.tripType)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Veículo</p>
            <p style="font-size:14px;font-weight:600;">{booking.vehicleType} · {booking.passengerCount} pax</p>
          </div>
          {booking.hotel && (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Hotel</p>
              <p style="font-size:14px;">🏨 {booking.hotel}</p>
            </div>
          )}
          {booking.idaDate && (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Chegada</p>
              <p style="font-size:14px;">✈️ {fmtDate(booking.idaDate)}{booking.idaFlightTime ? ` às ${booking.idaFlightTime}` : ""}{booking.idaFlightNumber ? ` · Voo ${booking.idaFlightNumber}` : ""}</p>
            </div>
          )}
          {booking.voltaDate && (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Retorno</p>
              <p style="font-size:14px;">↩️ {fmtDate(booking.voltaDate)}{booking.voltaFlightTime ? ` às ${booking.voltaFlightTime}` : ""}{booking.voltaFlightNumber ? ` · Voo ${booking.voltaFlightNumber}` : ""}</p>
            </div>
          )}
        </div>
      </div>

      <!-- Financeiro -->
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;">
        <h2 style="font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;">💰 Financeiro</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Total</p>
            <p style="font-size:22px;font-weight:800;color:#3ecf8e;">{brl(booking.totalCents)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Já Recebido</p>
            <p style="font-size:22px;font-weight:800;color:var(--text);">{brl(booking.totalCents - booking.remainderCents)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">A Receber</p>
            <p style={`font-size:22px;font-weight:800;color:${booking.remainderCents > 0 ? "#c9a84c" : "var(--muted)"};`}>{brl(booking.remainderCents)}</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Pagamento</p>
            <p style="font-size:14px;text-transform:uppercase;">{booking.payMethod === "pix" ? "PIX" : booking.payMethod === "cartao" ? "Cartão" : booking.payMethod}</p>
          </div>
          {booking.affiliateCode && (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Afiliado</p>
              <p style="font-size:14px;color:var(--gold);">👥 {booking.affiliateCode}</p>
            </div>
          )}
        </div>
      </div>

      <!-- Motorista -->
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;">
        <h2 style="font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;">🚗 Motorista</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
          {booking.driverInName ? (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Chegada IN</p>
              <p style="font-size:14px;font-weight:600;">{booking.driverInName}</p>
              {booking.driverInCar && <p style="font-size:12px;color:var(--muted);">{booking.driverInCar}</p>}
              {booking.driverInWhatsapp && <a href={`https://wa.me/55${booking.driverInWhatsapp}`} target="_blank" style="font-size:12px;color:#3ecf8e;text-decoration:none;">💬 {booking.driverInWhatsapp}</a>}
            </div>
          ) : (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Chegada IN</p>
              <p style="font-size:13px;color:#c9a84c;">⚠️ Não designado</p>
            </div>
          )}
          {booking.driverOutName ? (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Retorno OUT</p>
              <p style="font-size:14px;font-weight:600;">{booking.driverOutName}</p>
              {booking.driverOutCar && <p style="font-size:12px;color:var(--muted);">{booking.driverOutCar}</p>}
            </div>
          ) : booking.tripType !== "ida" ? (
            <div>
              <p style="font-size:11px;color:var(--muted);margin-bottom:4px;">Retorno OUT</p>
              <p style="font-size:13px;color:#c9a84c;">⚠️ Não designado</p>
            </div>
          ) : null}
        </div>
      </div>

      <!-- Ações -->
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <a href={`/admin/reservas/${id}/editar`} style="padding:10px 18px;background:var(--gold);color:#05080d;border-radius:10px;text-decoration:none;font-size:13px;font-weight:700;">Editar Reserva</a>
        <a href="/admin/reservas" style="padding:10px 18px;border:1px solid var(--border);color:var(--muted);border-radius:10px;text-decoration:none;font-size:13px;">← Voltar</a>
      </div>
    </div>
  </div>
</AdminLayout>
