---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";

const hasError = !!Astro.url.searchParams.get("error");
---
<AdminLayout title="Novo Item de Estoque | Admin" currentPath="/admin/estoque">
  <div style="padding:32px 40px;">
    <div style="max-width:600px;">
      <div style="margin-bottom:24px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--muted);margin-bottom:6px;">Admin · Gestão</p>
        <h1 style="font-size:22px;font-weight:700;">📦 Novo Item de Estoque</h1>
        <p style="font-size:13px;color:var(--muted);margin-top:4px;">Cadastro manual. Para registrar a entrada de uma compra, use <a href="/admin/compras/novo" style="color:var(--gold);">Registrar compra</a>.</p>
      </div>

      {hasError && (
        <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);border-radius:10px;padding:10px 14px;font-size:13px;color:var(--red);margin-bottom:16px;">
          Preencha ao menos o tipo e a quantidade.
        </div>
      )}

      <form action="/api/admin/estoque-item" method="POST" style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;display:flex;flex-direction:column;gap:16px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Tipo *</label>
            <input name="tipo" required placeholder="Ex: Camiseta" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Tamanho</label>
            <input name="tamanho" placeholder="Ex: 40x50" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Gramatura</label>
            <input name="gramatura" placeholder="Ex: 0,05" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Cor</label>
            <input name="cor" placeholder="Ex: Preta" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Quantidade *</label>
            <input name="quantidade" type="number" step="1" min="0" required placeholder="Ex: 500" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">Mínimo (alerta)</label>
            <input name="minimo" type="number" step="1" min="0" placeholder="Ex: 100" style="width:100%;background:rgba(20,30,45,0.045);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
        </div>

        <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:8px;">
          <a href="/admin/estoque" style="padding:12px 20px;border:1px solid var(--border);border-radius:10px;color:var(--muted);text-decoration:none;font-size:13px;font-weight:600;">Cancelar</a>
          <button type="submit" style="padding:12px 24px;background:var(--gold);color:#05080d;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Salvar →</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>
