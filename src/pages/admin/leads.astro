---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { prisma } from "../../lib/prisma";

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") ?? "PENDING";

const orcamentos = await prisma.pedido.findMany({
  where: { status: statusFilter === "todos" ? undefined : statusFilter },
  orderBy: { createdAt: "desc" },
  take: 100,
  select: {
    id: true,
    numeroPedido: true,
    createdAt: true,
    status: true,
    totalCents: true,
    tipoProduto: true,
    quantidade: true,
    internalNotes: true,
    affiliateCode: true,
    customer: { select: { name: true, phone: true } },
  },
});

const total = orcamentos.length;

const tipoLabel: Record<string, string> = {
  alca_vazada: "Alça Vazada",
  alca_fita: "Alça Fita",
  alca_camiseta: "Alça Camiseta",
  boca_palhaço: "Alça Vazada",
  outro: "Outro",
};

function brl(cents: number) {
  return (cents / 100).toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
}
function fmtDate(d: Date) {
  return new Date(d).toLocaleDateString("pt-BR", { day: "2-digit", month: "2-digit", year: "numeric" });
}

const statusConfig: Record<string, { label: string; color: string; bg: string; border: string }> = {
  PENDING:   { label: "Aguardando", color: "#c9a84c", bg: "rgba(201,168,76,0.1)",   border: "rgba(201,168,76,0.3)" },
  CONFIRMED: { label: "Convertido",  color: "#3ecf8e", bg: "rgba(62,207,142,0.1)",  border: "rgba(62,207,142,0.25)" },
  CANCELLED: { label: "Cancelado",   color: "#f87171", bg: "rgba(248,113,113,0.1)", border: "rgba(248,113,113,0.25)" },
};
---

<AdminLayout title="Orçamentos | Admin" currentPath="/admin/leads">
  <div style="padding:32px 40px;">
    <div style="max-width:1100px;">

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
        <div>
          <h1 style="font-size:22px;font-weight:700;margin-bottom:4px;">🎯 Orçamentos</h1>
          <p style="font-size:13px;color:var(--muted);">{total} orçamento{total !== 1 ? "s" : ""} encontrado{total !== 1 ? "s" : ""}</p>
        </div>
        <a href="/admin/leads/novo" style="background:var(--gold);color:#05080d;padding:10px 16px;border-radius:10px;font-size:13px;font-weight:600;text-decoration:none;">+ Novo Orçamento</a>
      </div>

      <!-- Filtros -->
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px;">
        {[
          { value: "PENDING",   label: "Aguardando" },
          { value: "CONFIRMED", label: "Convertidos" },
          { value: "CANCELLED", label: "Cancelados" },
          { value: "todos",     label: "Todos" },
        ].map(f => (
          <a href={`/admin/leads?status=${f.value}`}
             style={`padding:7px 16px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;border:1px solid var(--border);transition:all 0.15s;${statusFilter === f.value ? "background:var(--gold);color:#05080d;border-color:var(--gold);" : "color:var(--muted);"}`}>
            {f.label}
          </a>
        ))}
      </div>

      {orcamentos.length === 0 ? (
        <div style="text-align:center;padding:60px;color:var(--muted);background:var(--bg-card);border:1px solid var(--border);border-radius:14px;">
          Nenhum orçamento encontrado.
        </div>
      ) : (
        <div style="display:flex;flex-direction:column;gap:10px;">
          {orcamentos.map((o) => {
            const sc = statusConfig[o.status] ?? statusConfig["PENDING"];
            return (
              <div style={`background:var(--bg-card);border:1px solid ${o.status === "PENDING" ? "rgba(201,168,76,0.2)" : "var(--border)"};border-radius:14px;padding:18px 24px;display:grid;grid-template-columns:2fr 1fr 1fr auto;gap:16px;align-items:center;`}>
                <div>
                  <div style="display:flex;align-items:center;gap:8px;margin-bottom:2px;">
                    <p style="font-size:14px;font-weight:600;">{o.customer?.name || "Cliente não informado"}</p>
                    {o.numeroPedido && <span style="font-size:11px;font-weight:700;color:var(--gold);background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.3);padding:2px 8px;border-radius:20px;">{o.numeroPedido}</span>}
                  </div>
                  <p style="font-size:12px;color:var(--muted);">{o.customer?.phone || "—"}</p>
                  <p style="font-size:11px;color:var(--muted);margin-top:3px;">
                    {tipoLabel[o.tipoProduto] || o.tipoProduto}
                    {o.quantidade ? ` · ${o.quantidade} un` : ""}
                  </p>
                  {o.internalNotes && <p style="font-size:11px;color:var(--muted);margin-top:2px;">📝 {o.internalNotes.slice(0, 60)}{o.internalNotes.length > 60 ? "..." : ""}</p>}
                </div>
                <div>
                  <p style="font-size:11px;color:var(--muted);">Data</p>
                  <p style="font-size:13px;margin-top:2px;">{fmtDate(o.createdAt)}</p>
                </div>
                <div>
                  <p style="font-size:16px;font-weight:700;color:#3ecf8e;">{o.totalCents > 0 ? brl(o.totalCents) : <span style="color:var(--muted);font-size:13px;">A definir</span>}</p>
                </div>
                <div style="display:flex;flex-direction:column;gap:8px;align-items:flex-end;">
                  <span style={`padding:4px 12px;border-radius:100px;font-size:11px;font-weight:600;white-space:nowrap;color:${sc.color};background:${sc.bg};border:1px solid ${sc.border};`}>
                    {sc.label}
                  </span>
                  {o.status === "PENDING" && (
                    <form action="/api/admin/converter-pedido" method="POST">
                      <input type="hidden" name="id" value={o.id} />
                      <button type="submit" style="background:var(--gold);color:#05080d;border:none;border-radius:8px;padding:6px 12px;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;">
                        ✓ Converter em Pedido
                      </button>
                    </form>
                  )}
                  {o.status === "CONFIRMED" && (
                    <a href={`/admin/reservas/${o.id}`} style="font-size:11px;color:var(--muted);text-decoration:none;">Ver pedido →</a>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </div>
</AdminLayout>
