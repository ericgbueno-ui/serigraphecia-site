---
export const prerender = false;
import { prisma } from "../../lib/prisma";
import jwt from "jsonwebtoken";

const token = Astro.cookies.get("rep_token")?.value ?? "";
let rep: any = null;

try {
  const secret = import.meta.env.JWT_SECRET || process.env.JWT_SECRET || "fallback_secret";
  const decoded = jwt.verify(token, secret) as { id: string; code: string };
  rep = await prisma.representante.findUnique({
    where: { id: decoded.id },
    include: { payments: true },
  });
} catch {
  return Astro.redirect("/representante");
}

if (!rep) return Astro.redirect("/representante");

const pedidos = await prisma.pedido.findMany({
  where: { affiliateCode: rep.code, status: { notIn: ["CANCELLED", "PENDING"] } },
  orderBy: { createdAt: "desc" },
  select: {
    id: true,
    numeroPedido: true,
    createdAt: true,
    totalCents: true,
    commissionCents: true,
    status: true,
    customer: { select: { name: true } },
  },
});

const totalComm   = pedidos.reduce((s, p) => s + (p.commissionCents || 0), 0);
const totalPago   = rep.payments.reduce((s: number, p: any) => s + p.amountCents, 0);
const pendente    = totalComm - totalPago;
const pct         = rep.comissaoPct ? Number(rep.comissaoPct) : 0;

function brl(cents: number) {
  return (cents / 100).toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
}
function fmtDate(d: Date) {
  return new Date(d).toLocaleDateString("pt-BR", { day: "2-digit", month: "2-digit", year: "numeric" });
}

const now      = new Date();
const horaNum  = parseInt(now.toLocaleString("pt-BR", { timeZone: "America/Sao_Paulo", hour: "numeric", hour12: false }));
const saudacao = horaNum < 12 ? "Bom dia" : horaNum < 18 ? "Boa tarde" : "Boa noite";
