---
import { getIsAdmin, ADMIN_COOKIE_NAME } from "../lib/server/adminAuth";
import { AdminShell } from "../components/admin/AdminShell";

interface Props {
  title?: string;
}

const { title = "Admin | Serigraph e Cia" } = Astro.props;

const cookieVal = Astro.cookies.get(ADMIN_COOKIE_NAME)?.value ?? "";
const isAdmin = getIsAdmin(cookieVal);

if (!isAdmin) {
  return Astro.redirect("/admin");
}

const currentPath = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --bg: #eef1f3;
        --bg-card: #ffffff;
        --text: #1c2230;
        --muted: #667085;
        --border: rgba(20,30,45,0.09);
        --border-md: rgba(20,30,45,0.16);
        --gold: #a9802e;
        --gold-dim: rgba(169,128,46,0.10);
        --gold-line: rgba(169,128,46,0.35);
        --red: #dc2626;
        --mt-gold: #a9802e;
      }
      body {
        font-family: 'DM Sans', system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
        overflow-x: hidden;
      }
      a { color: inherit; }
    </style>
    <!-- is:global: estilos de <style> são escopados pelo Astro e não alcançam
         os <select> renderizados pelas páginas via <slot> -->
    <style is:global>
      select {
        color-scheme: light;
      }
      select option,
      select optgroup {
        background-color: #ffffff;
        color: #1c2230;
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <AdminShell currentPath={currentPath} client:load>
      <slot />
    </AdminShell>
  </body>
</html>
