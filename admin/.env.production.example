NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=123456789012345
NEXT_PUBLIC_SITE_URL=https://multitrip.com.br

# Core backend
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
# Optional: only required if Redis-backed jobs/cache are enabled.
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=

# Observability / auth
APP_ORIGIN=https://multitrip.com.br
API_ORIGIN=https://api.multitrip.com.br
CORS_ALLOWED_ORIGINS=https://multitrip.com.br,https://www.multitrip.com.br
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
STRIPE_KEY=
MERCADOPAGO_TOKEN=
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
META_PIXEL_ID=123456789012345

