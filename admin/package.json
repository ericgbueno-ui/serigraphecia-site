{
  "name": "multitrip-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check": "npm run format:check && npm run lint && npm run typecheck",
    "fix": "prettier --write . && eslint . --fix",
    "dev": "next dev",
    "build": "prisma generate && node scripts/migrate-resolve.mjs && next build",
    "start": "next start",
    "vistoria": "npm run format:check && npm run lint && npm run typecheck && npm run deps && npm run audit",
    "lint": "eslint . --cache",
    "typecheck": "tsc --noEmit",
    "deps": "depcheck",
    "audit": "npm audit --audit-level=high",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:reset": "echo '\\n⛔  OPERAÇÃO BLOQUEADA\\nPrisma migrate reset APAGA TODOS OS DADOS.\\nSe tiver certeza absoluta, rode manualmente:\\n  npx prisma migrate reset\\n' && exit 1",
    "check:env": "node ./scripts/check-env.mjs",
    "setup:dev": "node ./scripts/setup-dev.mjs",
    "prisma:create-affiliate": "ts-node --compiler-options '{\\\"module\\\":\\\"commonjs\\\"}' scripts/create-affiliate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@vercel/analytics": "^2.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "dotenv": "^17.4.1",
    "framer-motion": "^11.11.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "next": "^16.2.2",
    "nodemailer": "^8.0.1",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "puppeteer": "^25.0.4",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "@xyflow/react": "^12.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "depcheck": "^1.4.7",
    "eslint": "^9.8.0",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "dotenv": "^17.4.1"
  }
}
