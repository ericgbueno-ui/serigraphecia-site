generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────
// LEAD / CRM
// ─────────────────────────────────────────────

/// Lead capturado automaticamente via WhatsApp, site ou checkout
model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Número E.164, ex: 5551999999999 — chave de identificação
  whatsapp    String   @unique
  name        String?
  email       String?

  /// Rota de interesse (ex: "porto-alegre-gramado")
  origin      String?
  destination String?

  /// Datas e passageiros informados na conversa
  travelDate  DateTime?
  passengers  Int?

  /// Valor estimado do transfer (em centavos)
  valueCents  Int?

  /// Score acumulado pelo motor de pontuação
  score       Int      @default(0)

  /// frio | interessado | quente | pronto | convertido
  status      String   @default("frio")

  /// Canal de entrada: whatsapp | site | checkout | abandonment
  source      String   @default("whatsapp")

  /// UTMs de atribuição
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  interactions Interaction[]
  events       LeadEvent[]
  jolieMemory  JolieClientMemory?

  @@index([status])
  @@index([score])
  @@index([createdAt])
}

/// Cada mensagem trocada com a Jolie ou com a equipe
model Interaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// "lead" | "jolie" | "human"
  role      String

  /// Texto da mensagem
  content   String   @db.Text

  /// Motor de IA que respondeu: claude | gemini | gpt | human
  aiEngine  String?

  @@index([leadId])
  @@index([createdAt])
}

/// Eventos comportamentais do lead
model LeadEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// page_view | whatsapp_click | quote_request | checkout_start | purchase | no_response
  type      String

  /// Pontos adicionados neste evento
  points    Int      @default(0)

  /// Metadados livres: página, veículo, valor, etc.
  meta      Json?

  @@index([leadId])
  @@index([type])
}

model Customer {
  id             String    @id @default(cuid())
  name           String
  email          String
  phone          String    @unique
  /// CPF do contratante (sem pontuação). Permite lookup por CPF quando WhatsApp não informado.
  cpf            String?   @unique
  marketingOptIn Boolean   @default(false)
  birthDate      DateTime?

  bookings       Booking[]

  @@index([phone])
  @@index([cpf])
}

model Affiliate {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  name         String
  email        String
  whatsapp     String
  code         String    @unique
  password     String
  active       Boolean   @default(true)
  type         String    @default("agency")
  commIda      Int       @default(2500)
  commIdaVolta Int       @default(5000)

  payments     AffiliatePayment[]

  @@index([active])
}

model AffiliatePayment {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  amountCents Int
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id                      String     @id @default(cuid())
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  publicToken             String     @unique
  affiliateCode           String?
  commissionCents         Int?
  commissionPaid          Boolean    @default(false)
  routeLabel              String?
  origin                  String
  dest                    String
  tripType                String
  vehicleType             String
  passengerCount          Int
  hotel                   String?
  hotelAddress            String?
  idaDate                 DateTime?
  idaFlightTime           String?
  idaFlightNumber         String?
  voltaDate               DateTime?
  voltaFlightTime         String?
  voltaFlightNumber       String?
  payMethod               String
  totalCents              Int
  depositCents            Int
  remainderCents          Int
  optionalsJson           String?
  optionalsCents          Int        @default(0)
  contractAcceptedAt      DateTime?
  contractAcceptedVersion String?
  status                  String
  mpPreferenceId          String?
  zohoEventUid            String?
  driverName              String?
  driverCar               String?
  driverWhatsapp          String?
  driverNotifiedAt        DateTime?
  contractPdfUrl          String?
  driverInName            String?
  driverInCar             String?
  driverInWhatsapp        String?
  driverOutName           String?
  driverOutCar            String?
  driverOutWhatsapp       String?
  driverCityTourName      String?
  driverCityTourCar       String?
  driverCityTourWhatsapp  String?
  /// Valor pago ao motorista da chegada (IN) em centavos
  driverInPaymentCents     Int?
  /// Valor pago ao motorista do retorno (OUT) em centavos
  driverOutPaymentCents    Int?
  /// Valor pago ao motorista do city tour em centavos
  driverCityTourPaymentCents Int?
  idaConcluida            Boolean    @default(false)
  voltaConcluida          Boolean    @default(false)
  cityTourConcluido       Boolean    @default(false)
  reviewRequestedAt       DateTime?
  /// Observações internas da equipe (não visível ao cliente)
  internalNotes           String?    @db.Text
  /// Ponto de embarque alternativo quando não é o aeroporto (ex: hotel na cidade)
  pickupAddress           String?
  /// Número de veículos utilizados (ex: 2 sedans para grupos grandes)
  vehicleCount            Int        @default(1)
  /// Tipo do segundo veículo quando vehicleCount > 1
  secondVehicle           String?
  customerId              String
  customer                Customer   @relation(fields: [customerId], references: [id])

  passengers              Passenger[]
  payments                Payment[]

  @@index([status])
}

model Passenger {
  id        String  @id @default(cuid())
  fullName  String
  docType   String
  docNumber String
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])
}

model Payment {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  method      String
  status      String
  amountCents Int
  bookingId   String
  booking     Booking   @relation(fields: [bookingId], references: [id])
  providerId  String?   @unique
  paidAt      DateTime?

  /// Referência para rastreamento de cashflow
  cashflowTransactions CashflowTransaction[]
}

// ─────────────────────────────────────────────
// CASHFLOW / FINANCIAL MANAGEMENT
// ─────────────────────────────────────────────

/// Categorias de transações (renda, despesa, etc.)
model CashflowCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  type        String    /// "INCOME" | "EXPENSE"
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  transactions CashflowTransaction[]

  @@index([type])
}

/// Transações de fluxo de caixa por motorista
model CashflowTransaction {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  transactionDate   DateTime

  /// ID do motorista (driver/motorista)
  motoristaId       String

  /// Categoria da transação
  categoryId        String
  category          CashflowCategory @relation(fields: [categoryId], references: [id])

  /// INCOME | EXPENSE
  transactionType   String

  /// Valor em centavos
  amountCents       Int

  /// Descrição da transação
  description       String    @db.Text

  /// Referência opcional (paymentId, viagemId, etc.)
  referencePaymentId String?
  payment           Payment?  @relation(fields: [referencePaymentId], references: [id], onDelete: SetNull)

  @@index([motoristaId])
  @@index([categoryId])
  @@index([transactionType])
  @@index([transactionDate])
  @@index([motoristaId, transactionDate])
}

// ─────────────────────────────────────────────
// META ADS SPEND
// ─────────────────────────────────────────────

/// Gasto diário no Meta Ads — atualizado 3× ao dia via cron
model MetaAdSpend {
  id          String   @id @default(cuid())
  /// Data do gasto no formato "YYYY-MM-DD"
  date        String
  /// ID da conta de anúncios (ex: act_1234567890)
  accountId   String
  /// Gasto em BRL
  spend       Float    @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  reach       Int      @default(0)
  /// Quando foi atualizado pela última vez
  fetchedAt   DateTime @default(now())

  @@unique([date, accountId])
  @@index([date])
}

// ─────────────────────────────────────────────
// JOLIE — SISTEMA DE INTELIGÊNCIA VETORIAL
// ─────────────────────────────────────────────

/// Versões do prompt mestre da Jolie — fonte de verdade do cérebro
model JolieBrain {
  id         String   @id @default(cuid())
  version    Int      @default(1)
  active     Boolean  @default(false)
  corePrompt String   @db.Text
  note       String?
  updatedBy  String?  @default("seed")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
  @@index([version])
}

/// Base de conhecimento vetorial da Jolie — alimentada pelo ia-jolie-cerebro, conversas e pesquisas
model JolieKnowledge {
  id          String   @id @default(cuid())
  type        String
  title       String
  content     String   @db.Text
  source      String   @default("manual")
  sourceRef   String?
  embedding   Unsupported("vector(1536)")?
  successRate Float    @default(0)
  usageCount  Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([active])
  @@index([source])
}

/// Memória persistente da Jolie por cliente
model JolieClientMemory {
  id          String   @id @default(cuid())
  leadId      String   @unique
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  profile     String   @default("desconhecido")
  summary     String?  @db.Text
  preferences Json?
  embedding   Unsupported("vector(1536)")?
  updatedAt   DateTime @updatedAt

  @@index([profile])
}

/// Insights extraídos de conversas — processados pelo learning loop
model JolieInsight {
  id         String   @id @default(cuid())
  leadId     String?
  converted  Boolean  @default(false)
  content    String   @db.Text
  type       String
  embedding  Unsupported("vector(1536)")?
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([converted])
  @@index([processed])
  @@index([type])
}

/// Sessão de conversa da Jolie (site widget) — separada do CRM WhatsApp
model JolieConversation {
  id             String   @id @default(cuid())
  /// Identificador de sessão: phone (WhatsApp) ou cookie (site)
  sessionId      String   @unique
  phone          String?
  /// Canal de origem: site | whatsapp
  channel        String   @default("site")
  /// Histórico [{role:"user"|"assistant", content:string, timestamp:string}]
  history        Json     @default("[]")
  /// Intenção detectada: reserva | duvida | roteiro | objecao | reclamacao | outro
  intent         String?
  /// true quando Jolie decide escalar para atendimento humano
  handoffToHuman Boolean  @default(false)
  lastActivity   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([phone])
  @@index([channel])
  @@index([lastActivity])
}

// ─────────────────────────────────────────────
// MOTORISTAS PARCEIROS (FROTA)
// ─────────────────────────────────────────────

model Driver {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  name          String
  phone         String
  password      String
  carModel      String
  carColor      String
  carYear       String
  carPlate      String
  hybridOrElectric String? // "Combustão", "Híbrido", "100% Elétrico"
  pixKey        String
  cadastur      String?
  companyType   String   // EX: "Autônomo", "Autônomo MEI", "Empresa/Agência"
  acceptedTerms Boolean  @default(false)

  @@index([status])
  @@index([phone])
}

// ─────────────────────────────────────────────
// B2B CONTACTS
// ─────────────────────────────────────────────

/// Agencias parceiras B2B para prospeccao via WhatsApp e e-mail
model B2bContact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  city      String?
  state     String?
  instagram String?
  whatsapp  String?
  email     String?
  site      String?
  notes     String?

  /// "a_enviar" | "enviado" | "respondeu" | "parceiro" | "descartado"
  status    String   @default("a_enviar")
  sentAt    DateTime?

  @@index([status])
  @@index([state])
}

// ─────────────────────────────────────────────
// EMAIL MARKETING (RESEND)
// ─────────────────────────────────────────────

/// Campanhas de e-mail criadas no painel admin
model EmailCampaign {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  /// Título interno (não aparece no e-mail)
  title          String

  /// Assunto do e-mail
  subject        String

  /// Corpo em texto puro (o HTML é gerado no envio)
  body           String    @db.Text

  /// URL do botão CTA (opcional)
  ctaText        String?
  ctaUrl         String?

  /// "clientes" | "leads" | "ambos" | "manual"
  audience       String    @default("clientes")

  /// E-mails manuais separados por vírgula (quando audience = "manual")
  manualEmails   String?   @db.Text

  /// "draft" | "sending" | "sent" | "error"
  status         String    @default("draft")

  sentAt         DateTime?
  recipientCount Int       @default(0)
  sentCount      Int       @default(0)
  failedCount    Int       @default(0)

  /// JSON array de { email, name?, status: "sent"|"failed" } — salvo no envio
  recipientsJson String?   @db.Text

  /// Follow-up automático (B2B): data do último envio
  followupSentAt    DateTime?
  /// Número de follow-ups enviados
  followupCount     Int       @default(0)
  /// Assunto do follow-up (gerado automaticamente se null)
  followupSubject   String?
  /// JSON array de destinatários do follow-up (mesmo formato de recipientsJson)
  followupRecipientsJson String? @db.Text

  @@index([status])
  @@index([createdAt])
  @@index([followupSentAt])
}

// ─────────────────────────────────────────────
// AGENDAMENTO DE E-MAIL EM LOTES (WARMUP)
// ─────────────────────────────────────────────

/// Disparo gradual para aquecimento de domínio de e-mail
model EmailBatchJob {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Audiência alvo ("b2b" | "clientes" | "leads")
  audience    String   @default("b2b")

  /// Conteúdo do e-mail
  subject     String
  body        String   @db.Text
  ctaText     String?
  ctaUrl      String?

  /// "active" | "paused" | "completed" | "cancelled"
  status      String   @default("active")

  totalTarget Int      @default(0)
  totalSent   Int      @default(0)

  /// JSON: Array<{ sendAt: string; batchSize: number; sent: boolean; sentAt?: string; sentCount?: number; failedCount?: number }>
  scheduleJson String  @db.Text

  @@index([status])
}

// ─────────────────────────────────────────────
// SESSÃO WHATSAPP (BAILEYS)
// ─────────────────────────────────────────────

/// Guarda as credenciais de autenticação do WhatsApp Web em formato JSON para reconexão via Baileys
model WhatsappSession {
  id        String   @id @default(cuid())
  phone     String   @unique
  data      String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// SISTEMA DE AUTOMAÇÃO (Motor próprio, sem n8n)
// ─────────────────────────────────────────────

/// Fluxo de automação — define gatilho + sequência de passos
model AutomationFlow {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  name          String
  description   String?
  active        Boolean         @default(true)

  /// SCHEDULE | WEBHOOK | EVENT
  triggerType   String
  /// SCHEDULE: {cron:"0 9 * * *"} | WEBHOOK: {token:"xyz"} | EVENT: {event:"payment_confirmed"}
  triggerConfig Json

  /// Array de passos: [{id, type, label, config}]
  steps         Json            @default("[]")

  runs          AutomationRun[]

  @@index([active])
  @@index([triggerType])
}

/// Registro de execução de um fluxo de automação
model AutomationRun {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())

  flowId      String
  flow        AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  /// pending | running | completed | failed
  status      String         @default("pending")

  /// Dados de entrada que dispararam este fluxo
  inputData   Json?

  /// Logs de cada passo: [{stepId, label, ok, message, ts}]
  logs        Json           @default("[]")

  error       String?        @db.Text
  completedAt DateTime?

  @@index([flowId])
  @@index([status])
  @@index([createdAt])
}

