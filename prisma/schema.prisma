generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USUÁRIOS INTERNOS / AUTENTICAÇÃO (Fase 1 — auditoria 2026-07-01)
// ─────────────────────────────────────────────

/// Colaborador com acesso individual ao painel administrativo.
/// Substitui gradualmente a senha única compartilhada (ADMIN_PASSWORD).
model User {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  name         String
  email        String    @unique
  /// Hash scrypt (nunca a senha em texto puro)
  passwordHash String

  /// admin | equipe (papéis futuros podem ser adicionados sem quebrar o existente)
  role         String    @default("admin")
  active       Boolean   @default(true)
  lastLoginAt  DateTime?

  historico    HistoricoAlteracao[]
  loginAttempts LoginAttempt[]
  pedidosCancelados Pedido[]

  @@index([active])
}

/// Registro de cada tentativa de login (sucesso ou falha) — base do rate limit
/// e de rastreabilidade de acesso. Nunca é apagado.
model LoginAttempt {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  /// IP de origem da tentativa (chave principal do rate limit)
  ip         String
  /// E-mail informado, se houver (login individual) — pode não existir (login legado)
  email      String?
  success    Boolean

  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ip, createdAt])
  @@index([email, createdAt])
}

/// Log de auditoria genérico: qualquer alteração relevante em qualquer entidade
/// (Pedido, Estoque, Cliente, etc.) pode gravar um registro aqui. Nunca é apagado.
model HistoricoAlteracao {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  /// Nome da entidade alterada (ex: "Pedido", "Estoque", "Customer")
  entidade      String
  /// ID do registro alterado
  entidadeId    String
  /// Nome do campo alterado (ex: "dataPrevistaEntrega", "status")
  campo         String
  valorAnterior String?  @db.Text
  valorNovo     String?  @db.Text

  /// Motivo da alteração, quando informado pelo usuário
  motivo        String?  @db.Text

  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entidade, entidadeId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// LEAD / CRM
// ─────────────────────────────────────────────

/// Lead capturado automaticamente via WhatsApp, site ou checkout
model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Número E.164, ex: 5551999999999 — chave de identificação
  whatsapp    String   @unique
  name        String?
  email       String?

  /// Produto de interesse (ex: "camiseta", "sacola", "boné")
  produtoInteresse String?

  /// Quantidade estimada informada na conversa
  quantidadeEstimada Int?

  /// Valor estimado do pedido (em centavos)
  valueCents  Int?

  /// Score acumulado pelo motor de pontuação
  score       Int      @default(0)

  /// frio | interessado | quente | pronto | convertido
  status      String   @default("frio")

  /// Canal de entrada: whatsapp | site | checkout | abandonment
  source      String   @default("whatsapp")

  /// UTMs de atribuição
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  interactions Interaction[]
  events       LeadEvent[]

  @@index([status])
  @@index([score])
  @@index([createdAt])
}

/// Cada mensagem trocada com a equipe
model Interaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// "lead" | "human"
  role      String

  /// Texto da mensagem
  content   String   @db.Text

  @@index([leadId])
  @@index([createdAt])
}

/// Eventos comportamentais do lead
model LeadEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// page_view | whatsapp_click | quote_request | checkout_start | purchase | no_response
  type      String

  /// Pontos adicionados neste evento
  points    Int      @default(0)

  /// Metadados livres
  meta      Json?

  @@index([leadId])
  @@index([type])
}

model Customer {
  id             String    @id @default(cuid())
  /// Nome da pessoa de contato
  name           String
  /// Nome da loja/empresa do cliente (opcional, pode ser igual ao contato)
  nomeLoja       String?
  email          String
  phone          String    @unique
  instagram      String?
  /// Endereço — rua/número
  endereco       String?
  bairro         String?
  cidade         String?
  /// CPF do contratante (sem pontuação). Permite lookup por CPF quando WhatsApp não informado.
  cpf            String?   @unique
  marketingOptIn Boolean   @default(false)
  birthDate      DateTime?

  pedidos        Pedido[]

  @@index([phone])
  @@index([cpf])
}

model Representante {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  name        String
  email       String
  whatsapp    String
  code        String    @unique
  password    String
  active      Boolean   @default(true)
  type        String    @default("representante")

  /// Percentual de comissão sobre o valor do pedido (ex: 10 = 10%)
  comissaoPct Float     @default(0)

  payments    RepresentantePayment[]

  @@index([active])
}

model RepresentantePayment {
  id               String         @id @default(cuid())
  representanteId  String
  representante    Representante  @relation(fields: [representanteId], references: [id])
  amountCents      Int
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

/// Pedido de produção gráfica (serigrafia) — substitui o antigo modelo de reserva de transfer
model Pedido {
  id                      String     @id @default(cuid())
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  /// Número público sequencial, ex: SG-20260623-153012-AB12
  numeroPedido            String?    @unique
  publicToken             String     @unique
  affiliateCode           String?
  commissionCents         Int?
  commissionPaid          Boolean    @default(false)

  /// Tipo do produto (ex: camiseta, sacola, boné, ecobag)
  tipoProduto             String
  /// Cor do produto/peça
  corProduto              String?
  /// Tamanho do produto (ex: 20x30, 30x40)
  tamanho                 String?
  /// Gramatura/espessura da sacola, quando aplicável (ex: "0,10", "0,12")
  gramatura               String?
  /// Cor da tinta de impressão
  corImpressao            String?
  /// "um" | "dois" — lados de impressão
  lados                   String     @default("um")
  /// Quantidade de cores impressas no lado A
  coresLadoA              Int        @default(0)
  /// Quantidade de cores impressas no lado B
  coresLadoB              Int        @default(0)
  /// Quantidade de peças do pedido
  quantidade              Int        @default(1)

  payMethod               String
  totalCents              Int
  depositCents            Int
  remainderCents          Int
  /// JSON com a composição de adicionais/opcionais do orçamento
  optionalsJson           String?
  optionalsCents          Int        @default(0)

  contractAcceptedAt      DateTime?
  contractAcceptedVersion String?
  contractPdfUrl          String?

  status                  String

  /// Produção concluída / pronto para entrega
  producaoConcluida       Boolean    @default(false)
  reviewRequestedAt       DateTime?

  // ── Controle de datas independente (Fase 2 — auditoria 2026-07-01) ──────
  // createdAt acima já funciona como "Data de Cadastro" (preenchido
  // automaticamente pelo sistema). Os campos abaixo são independentes dele.

  /// Data em que o cliente efetivamente fez o pedido (pode ser anterior ao
  /// cadastro no sistema). Para pedidos antigos, foi preenchida com createdAt
  /// na migração — é a melhor informação disponível, não um dado inventado.
  dataPedido              DateTime?

  /// Previsão de início da produção
  dataPrevistaProducao    DateTime?
  /// Previsão de conclusão da produção
  dataPrevistaConclusao   DateTime?
  /// Data prometida ao cliente para entrega
  dataPrevistaEntrega     DateTime?
  /// Data em que o pedido foi efetivamente entregue (vazio até a confirmação)
  dataEntregaReal         DateTime?

  /// Data/hora do cancelamento, se houver. Pedido cancelado NUNCA é excluído.
  dataCancelamento        DateTime?
  motivoCancelamento      String?    @db.Text
  canceladoPorUserId      String?
  canceladoPor            User?      @relation(fields: [canceladoPorUserId], references: [id], onDelete: SetNull)

  /// Observações internas da equipe (não visível ao cliente)
  internalNotes           String?    @db.Text

  customerId              String
  customer                Customer   @relation(fields: [customerId], references: [id])

  payments                Payment[]
  itens                   ItemPedido[]
  ordemProducao           OrdemProducao?

  @@index([status])
  @@index([dataPedido])
  @@index([dataPrevistaEntrega])
  @@index([dataCancelamento])
}

// ─────────────────────────────────────────────
// PRODUÇÃO (Fase 4 — auditoria 2026-07-01)
// ─────────────────────────────────────────────

/// Fluxo fixo de etapas da produção, na ordem em que devem acontecer.
/// RECEBIDO -> AGUARDANDO_APROVACAO -> AGUARDANDO_PRODUCAO -> EM_PRODUCAO ->
/// PRODUCAO_FINALIZADA -> SEPARACAO -> PRONTO -> ENTREGUE -> FINALIZADO
/// (mantido como String, não enum, para não exigir migração de banco ao
/// ajustar o fluxo no futuro)
model OrdemProducao {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// Número sequencial legível (ex: OP-2026-0001)
  numero        String    @unique

  pedidoId      String    @unique
  pedido        Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  /// Ver fluxo fixo acima
  status        String    @default("RECEBIDO")
  /// baixa | normal | alta | urgente
  prioridade    String    @default("normal")

  responsavelId String?
  previsao      DateTime?
  observacoes   String?   @db.Text

  etapas        OrdemProducaoEtapa[]

  @@index([status])
  @@index([prioridade])
}

/// Histórico de cada mudança de etapa — nunca é apagado.
model OrdemProducaoEtapa {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())

  ordemId         String
  ordem           OrdemProducao @relation(fields: [ordemId], references: [id], onDelete: Cascade)

  etapa           String
  responsavelId   String?
  observacoes     String?       @db.Text

  @@index([ordemId])
}

/// Catálogo formal de produtos, com ID permanente — um pedido referencia o
/// produto por ID, então renomear/alterar o produto no catálogo nunca corrompe
/// pedidos antigos (o nome também fica gravado como snapshot em ItemPedido).
model Produto {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  codigo             String?   @unique
  nome               String
  categoria          String?
  modelo             String?
  descricao          String?   @db.Text
  imagemUrl          String?

  precoCents            Int?
  precoPromocionalCents Int?
  custoCents            Int?

  fornecedorId       String?
  fornecedor         Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)

  ativo              Boolean   @default(true)

  itens              ItemPedido[]

  @@index([ativo])
  @@index([categoria])
}

/// Um item (linha) dentro de um pedido. Um pedido pode ter quantos itens o
/// cliente quiser — sem limite. "nome"/"cor"/"tamanho" são um snapshot do
/// produto no momento da venda: se o produto for renomeado depois no catálogo,
/// este registro histórico não muda.
model ItemPedido {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())

  pedidoId           String
  pedido             Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  /// Referência ao catálogo, quando o item veio de um Produto cadastrado
  /// (opcional — itens antigos ou avulsos podem não ter produto vinculado)
  produtoId          String?
  produto            Produto?  @relation(fields: [produtoId], references: [id], onDelete: SetNull)

  /// Snapshot do nome do produto no momento da venda
  nome               String
  cor                String?
  tamanho            String?
  observacoes        String?   @db.Text

  quantidade         Int       @default(1)
  valorUnitarioCents Int       @default(0)
  subtotalCents      Int       @default(0)

  @@index([pedidoId])
  @@index([produtoId])
}

model Payment {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  method      String
  status      String
  amountCents Int
  pedidoId    String
  pedido      Pedido    @relation(fields: [pedidoId], references: [id])
  providerId  String?   @unique
  paidAt      DateTime?

  /// Referência para rastreamento de cashflow
  cashflowTransactions CashflowTransaction[]
}

// ─────────────────────────────────────────────
// CASHFLOW / FINANCIAL MANAGEMENT
// ─────────────────────────────────────────────

/// Categorias de transações (renda, despesa, etc.)
model CashflowCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  type        String    /// "INCOME" | "EXPENSE"
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  transactions CashflowTransaction[]

  @@index([type])
}

/// Transações de fluxo de caixa
model CashflowTransaction {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  transactionDate   DateTime

  /// Responsável/centro de custo (opcional)
  responsavelId     String?

  /// Categoria da transação
  categoryId        String
  category          CashflowCategory @relation(fields: [categoryId], references: [id])

  /// INCOME | EXPENSE
  transactionType   String

  /// Valor em centavos
  amountCents       Int

  /// Descrição da transação
  description       String    @db.Text

  /// Referência opcional (paymentId, etc.)
  referencePaymentId String?
  payment           Payment?  @relation(fields: [referencePaymentId], references: [id], onDelete: SetNull)

  @@index([responsavelId])
  @@index([categoryId])
  @@index([transactionType])
  @@index([transactionDate])
}

// ─────────────────────────────────────────────
// EMAIL MARKETING (RESEND)
// ─────────────────────────────────────────────

/// Campanhas de e-mail criadas no painel admin
model EmailCampaign {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  /// Título interno (não aparece no e-mail)
  title          String

  /// Assunto do e-mail
  subject        String

  /// Corpo em texto puro (o HTML é gerado no envio)
  body           String    @db.Text

  /// URL do botão CTA (opcional)
  ctaText        String?
  ctaUrl         String?

  /// "clientes" | "leads" | "ambos" | "manual"
  audience       String    @default("clientes")

  /// E-mails manuais separados por vírgula (quando audience = "manual")
  manualEmails   String?   @db.Text

  /// "draft" | "sending" | "sent" | "error"
  status         String    @default("draft")

  sentAt         DateTime?
  recipientCount Int       @default(0)
  sentCount      Int       @default(0)
  failedCount    Int       @default(0)

  /// JSON array de { email, name?, status: "sent"|"failed" } — salvo no envio
  recipientsJson String?   @db.Text

  /// Follow-up automático: data do último envio
  followupSentAt    DateTime?
  /// Número de follow-ups enviados
  followupCount     Int       @default(0)
  /// Assunto do follow-up (gerado automaticamente se null)
  followupSubject   String?
  /// JSON array de destinatários do follow-up (mesmo formato de recipientsJson)
  followupRecipientsJson String? @db.Text

  @@index([status])
  @@index([createdAt])
  @@index([followupSentAt])
}

// ─────────────────────────────────────────────
// AGENDAMENTO DE E-MAIL EM LOTES (WARMUP)
// ─────────────────────────────────────────────

/// Disparo gradual para aquecimento de domínio de e-mail
model EmailBatchJob {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Audiência alvo ("clientes" | "leads")
  audience    String   @default("clientes")

  /// Conteúdo do e-mail
  subject     String
  body        String   @db.Text
  ctaText     String?
  ctaUrl      String?

  /// "active" | "paused" | "completed" | "cancelled"
  status      String   @default("active")

  totalTarget Int      @default(0)
  totalSent   Int      @default(0)

  /// JSON: Array<{ sendAt: string; batchSize: number; sent: boolean; sentAt?: string; sentCount?: number; failedCount?: number }>
  scheduleJson String  @db.Text

  @@index([status])
}

// ─────────────────────────────────────────────
// SESSÃO WHATSAPP (BAILEYS)
// ─────────────────────────────────────────────

/// Guarda as credenciais de autenticação do WhatsApp Web em formato JSON para reconexão via Baileys
model WhatsappSession {
  id        String   @id @default(cuid())
  phone     String   @unique
  data      String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// SISTEMA DE AUTOMAÇÃO (Motor próprio, sem n8n)
// ─────────────────────────────────────────────

/// Fluxo de automação — define gatilho + sequência de passos
model AutomationFlow {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  name          String
  description   String?
  active        Boolean         @default(true)

  /// SCHEDULE | WEBHOOK | EVENT
  triggerType   String
  /// SCHEDULE: {cron:"0 9 * * *"} | WEBHOOK: {token:"xyz"} | EVENT: {event:"payment_confirmed"}
  triggerConfig Json

  /// Array de passos: [{id, type, label, config}]
  steps         Json            @default("[]")

  runs          AutomationRun[]

  @@index([active])
  @@index([triggerType])
}

/// Registro de execução de um fluxo de automação
model AutomationRun {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())

  flowId      String
  flow        AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  /// pending | running | completed | failed
  status      String         @default("pending")

  /// Dados de entrada que dispararam este fluxo
  inputData   Json?

  /// Logs de cada passo: [{stepId, label, ok, message, ts}]
  logs        Json           @default("[]")

  error       String?        @db.Text
  completedAt DateTime?

  @@index([flowId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// PRODUÇÃO / GESTÃO (preços, fornecedores, estoque)
// ─────────────────────────────────────────────

/// Catálogo dos modelos de sacola que vendemos (Alça Camiseta, Alça Vazada, Alça Fita)
model Modelo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nome      String   @unique
  ativo     Boolean  @default(true)

  precos    TabelaPreco[]
  custos    FornecedorCusto[]
}

/// Tabela de valores (preço de venda ao cliente) por modelo, tamanho e faixa de quantidade
model TabelaPreco {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// Mantido por compatibilidade (ex: "Alça Camiseta 40x50") — a fonte de verdade agora é modeloId + tamanho
  tipo          String

  modeloId      String?
  modelo        Modelo?  @relation(fields: [modeloId], references: [id])
  /// Tamanho no formato "40x50"
  tamanho       String?

  qtdMin        Int
  qtdMax        Int?
  precoUnitario Float
  ativo         Boolean  @default(true)
  notas         String?

  @@index([tipo])
  @@index([ativo])
  @@index([modeloId])
}

/// Custo de compra (o que pagamos) por fornecedor + modelo + tamanho + cor. Referência, não é preço de venda nem estoque físico.
model FornecedorCusto {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  fornecedorId String
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)

  modeloId     String
  modelo       Modelo     @relation(fields: [modeloId], references: [id])

  /// Tamanho no formato "40x50"
  tamanho      String
  /// Cor ou faixa de cor (ex: "Branco/Preto", "Colorida", "Diversas cores")
  cor          String?
  /// Espessura/gramatura (ex: "0,05")
  gramatura    String?

  precoKgCents       Int
  pesoMilheiroKg     Float?
  custoMilheiroCents Int?
  qtdPacote          Int?

  notas        String?

  @@index([fornecedorId])
  @@index([modeloId])
}

/// Fornecedores de matéria-prima (sacolas em branco, tintas, etc.)
model Fornecedor {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nome      String
  produto   String
  whatsapp  String?
  email     String?
  /// CNPJ do fornecedor (sem pontuação)
  cnpj      String?
  /// Razão social/empresa
  razaoSocial String?
  /// Endereço (rua e número)
  endereco  String?
  /// Bairro
  bairro    String?
  /// Cidade
  cidade    String?
  /// CEP
  cep       String?
  /// Estado (ex: SP)
  estado    String?
  /// Telefone fixo para contato
  telefone  String?
  /// Email adicional para contato
  emailAdicional String?
  /// Site do fornecedor
  site      String?
  /// Banco para depósitos (ex: "Itaú S/A")
  banco1    String?
  /// Agência do primeiro banco
  agencia1  String?
  /// Conta corrente do primeiro banco
  conta1    String?
  /// Segundo banco (se houver)
  banco2    String?
  /// Agência do segundo banco
  agencia2  String?
  /// Conta corrente do segundo banco
  conta2    String?
  ativo     Boolean  @default(true)

  /// Referência rápida em texto livre — mantido para fornecedores sem dados estruturados ainda (ver FornecedorCusto)
  tabelaCustos String? @db.Text

  compras   Compra[]
  custos    FornecedorCusto[]
  produtos  Produto[]

  @@index([ativo])
}

/// Controle de estoque de matéria-prima
model Estoque {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  produto    String
  tipo       String
  /// Tamanho do item (ex: "40x50")
  tamanho    String?
  /// Gramatura/espessura (ex: "0,05")
  gramatura  String?
  /// Cor do item
  cor        String?
  /// Quantidade de unidades por pacote (ex: 500, 250)
  quantidadePacote Int?
  /// Quantidade em estoque
  quantidade Float @default(0)
  /// Quantidade comprometida em pedidos abertos (Fase 3 — auditoria 2026-07-01).
  /// Disponível para vender = quantidade - quantidadeReservada (calculado no
  /// código, não gravado, para nunca ficar dessincronizado).
  quantidadeReservada Float @default(0)
  unidade    String   @default("un")
  minimo     Float    @default(0)
  /// Preço por kg em centavos (ex: 2890 = R$ 28,90)
  precoKgCents Int?
  /// Custo aproximado por milheiro em centavos
  custoMilheiroCents Int?

  movimentacoes MovimentacaoEstoque[]

  @@index([produto])
  @@index([tipo])
  @@index([tamanho])
  @@index([gramatura])
}

/// Histórico de cada entrada/saída de estoque — nunca é apagado
/// (Fase 3 — auditoria 2026-07-01).
model MovimentacaoEstoque {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  estoqueId     String
  estoque       Estoque  @relation(fields: [estoqueId], references: [id], onDelete: Cascade)

  /// ENTRADA | SAIDA | AJUSTE
  tipo          String
  quantidade    Float
  saldoAnterior Float
  saldoAtual    Float

  /// Pedido que originou a saída, quando aplicável
  pedidoId      String?
  /// Usuário responsável, quando identificável (login individual)
  userId        String?
  motivo        String?  @db.Text

  @@index([estoqueId])
  @@index([pedidoId])
  @@index([createdAt])
}

/// Configurações do sistema em chave/valor — permite mudar regras de negócio
/// (ex: em que etapa o estoque é baixado) sem alterar código-fonte
/// (Fase 3 — auditoria 2026-07-01).
model Configuracao {
  chave     String   @id
  valor     String
  descricao String?
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// COMPRAS DE MATÉRIA-PRIMA (notas de fornecedores)
// ─────────────────────────────────────────────

/// Cabeçalho de uma nota/pedido de compra de matéria-prima
model Compra {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  /// Número do pedido/nota do fornecedor (ex: 31676)
  numeroPedido   String?
  dataEmissao    DateTime?
  transportadora String?

  fornecedorId   String?
  fornecedor     Fornecedor?  @relation(fields: [fornecedorId], references: [id])

  /// Totais calculados a partir dos itens (somatório)
  totalPecas     Int          @default(0)
  totalKg        Float        @default(0)
  totalCents     Int          @default(0)

  observacao     String?      @db.Text

  itens          CompraItem[]

  /// Referência da despesa criada no Fluxo de Caixa (se aplicável)
  cashflowTransactionId String?

  @@index([fornecedorId])
  @@index([dataEmissao])
}

/// Linha de item de uma compra (uma sacola/modelo específico)
model CompraItem {
  id          String   @id @default(cuid())

  compraId    String
  compra      Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)

  /// Descrição livre, igual à nota (ex: "SAC AD 40X50X0,05 CAMISETA - PRETA")
  descricao   String

  /// Modelo/tipo da sacola (ex: "Camiseta", "Alça Fita", "Vazada")
  tipo        String
  /// Tamanho (ex: "40x50")
  tamanho     String?
  /// Gramatura/espessura (ex: "0,05")
  gramatura   String?
  /// Cor
  cor         String?

  /// Quantidade de peças (unidades)
  pecas       Int
  /// Peso em KG
  pesoKg      Float
  /// Preço por KG, em centavos
  precoKgCents Int
  /// Total da linha, em centavos
  totalCents  Int

  @@index([compraId])
}
