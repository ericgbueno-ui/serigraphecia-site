generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// LEAD / CRM
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Lead capturado automaticamente via WhatsApp, site ou checkout
model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// NГєmero E.164, ex: 5551999999999 вЂ” chave de identificaГ§ГЈo
  whatsapp    String   @unique
  name        String?
  email       String?

  /// Produto de interesse (ex: "camiseta", "sacola", "bonГ©")
  produtoInteresse String?

  /// Quantidade estimada informada na conversa
  quantidadeEstimada Int?

  /// Valor estimado do pedido (em centavos)
  valueCents  Int?

  /// Score acumulado pelo motor de pontuaГ§ГЈo
  score       Int      @default(0)

  /// frio | interessado | quente | pronto | convertido
  status      String   @default("frio")

  /// Canal de entrada: whatsapp | site | checkout | abandonment
  source      String   @default("whatsapp")

  /// UTMs de atribuiГ§ГЈo
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  interactions Interaction[]
  events       LeadEvent[]

  @@index([status])
  @@index([score])
  @@index([createdAt])
}

/// Cada mensagem trocada com a equipe
model Interaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// "lead" | "human"
  role      String

  /// Texto da mensagem
  content   String   @db.Text

  @@index([leadId])
  @@index([createdAt])
}

/// Eventos comportamentais do lead
model LeadEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// page_view | whatsapp_click | quote_request | checkout_start | purchase | no_response
  type      String

  /// Pontos adicionados neste evento
  points    Int      @default(0)

  /// Metadados livres
  meta      Json?

  @@index([leadId])
  @@index([type])
}

model Customer {
  id             String    @id @default(cuid())
  /// Nome da pessoa de contato
  name           String
  /// Nome da loja/empresa do cliente (opcional, pode ser igual ao contato)
  nomeLoja       String?
  email          String
  phone          String    @unique
  instagram      String?
  /// EndereГ§o вЂ” rua/nГєmero
  endereco       String?
  bairro         String?
  cidade         String?
  /// CPF do contratante (sem pontuaГ§ГЈo). Permite lookup por CPF quando WhatsApp nГЈo informado.
  cpf            String?   @unique
  marketingOptIn Boolean   @default(false)
  birthDate      DateTime?

  pedidos        Pedido[]

  @@index([phone])
  @@index([cpf])
}

model Representante {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  name        String
  email       String
  whatsapp    String
  code        String    @unique
  password    String
  active      Boolean   @default(true)
  type        String    @default("representante")

  /// Percentual de comissГЈo sobre o valor do pedido (ex: 10 = 10%)
  comissaoPct Float     @default(0)

  payments    RepresentantePayment[]

  @@index([active])
}

model RepresentantePayment {
  id               String         @id @default(cuid())
  representanteId  String
  representante    Representante  @relation(fields: [representanteId], references: [id])
  amountCents      Int
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

/// Pedido de produГ§ГЈo grГЎfica (serigrafia) вЂ” substitui o antigo modelo de reserva de transfer
model Pedido {
  id                      String     @id @default(cuid())
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  /// NГєmero pГєblico sequencial, ex: SG-20260623-153012-AB12
  numeroPedido            String?    @unique
  publicToken             String     @unique
  affiliateCode           String?
  commissionCents         Int?
  commissionPaid          Boolean    @default(false)

  /// Tipo do produto (ex: camiseta, sacola, bonГ©, ecobag)
  tipoProduto             String
  /// Cor do produto/peГ§a
  corProduto              String?
  /// Tamanho do produto (ex: 20x30, 30x40)
  tamanho                 String?
  /// Gramatura/espessura da sacola, quando aplicГЎvel (ex: "0,10", "0,12")
  gramatura               String?
  /// Cor da tinta de impressГЈo
  corImpressao            String?
  /// "um" | "dois" вЂ” lados de impressГЈo
  lados                   String     @default("um")
  /// Quantidade de cores impressas no lado A
  coresLadoA              Int        @default(0)
  /// Quantidade de cores impressas no lado B
  coresLadoB              Int        @default(0)
  /// Quantidade de peГ§as do pedido
  quantidade              Int        @default(1)

  payMethod               String
  totalCents              Int
  depositCents            Int
  remainderCents          Int
  /// JSON com a composiГ§ГЈo de adicionais/opcionais do orГ§amento
  optionalsJson           String?
  optionalsCents          Int        @default(0)

  contractAcceptedAt      DateTime?
  contractAcceptedVersion String?
  contractPdfUrl          String?

  status                  String

  /// ProduГ§ГЈo concluГ­da / pronto para entrega
  producaoConcluida       Boolean    @default(false)
  reviewRequestedAt       DateTime?

  /// ObservaГ§Гµes internas da equipe (nГЈo visГ­vel ao cliente)
  internalNotes           String?    @db.Text

  customerId              String
  customer                Customer   @relation(fields: [customerId], references: [id])

  payments                Payment[]

  @@index([status])
}

model Payment {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  method      String
  status      String
  amountCents Int
  pedidoId    String
  pedido      Pedido    @relation(fields: [pedidoId], references: [id])
  providerId  String?   @unique
  paidAt      DateTime?

  /// ReferГЄncia para rastreamento de cashflow
  cashflowTransactions CashflowTransaction[]
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// CASHFLOW / FINANCIAL MANAGEMENT
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Categorias de transaГ§Гµes (renda, despesa, etc.)
model CashflowCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  type        String    /// "INCOME" | "EXPENSE"
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  transactions CashflowTransaction[]

  @@index([type])
}

/// TransaГ§Гµes de fluxo de caixa
model CashflowTransaction {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  transactionDate   DateTime

  /// ResponsГЎvel/centro de custo (opcional)
  responsavelId     String?

  /// Categoria da transaГ§ГЈo
  categoryId        String
  category          CashflowCategory @relation(fields: [categoryId], references: [id])

  /// INCOME | EXPENSE
  transactionType   String

  /// Valor em centavos
  amountCents       Int

  /// DescriГ§ГЈo da transaГ§ГЈo
  description       String    @db.Text

  /// ReferГЄncia opcional (paymentId, etc.)
  referencePaymentId String?
  payment           Payment?  @relation(fields: [referencePaymentId], references: [id], onDelete: SetNull)

  @@index([responsavelId])
  @@index([categoryId])
  @@index([transactionType])
  @@index([transactionDate])
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// EMAIL MARKETING (RESEND)
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Campanhas de e-mail criadas no painel admin
model EmailCampaign {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  /// TГ­tulo interno (nГЈo aparece no e-mail)
  title          String

  /// Assunto do e-mail
  subject        String

  /// Corpo em texto puro (o HTML Г© gerado no envio)
  body           String    @db.Text

  /// URL do botГЈo CTA (opcional)
  ctaText        String?
  ctaUrl         String?

  /// "clientes" | "leads" | "ambos" | "manual"
  audience       String    @default("clientes")

  /// E-mails manuais separados por vГ­rgula (quando audience = "manual")
  manualEmails   String?   @db.Text

  /// "draft" | "sending" | "sent" | "error"
  status         String    @default("draft")

  sentAt         DateTime?
  recipientCount Int       @default(0)
  sentCount      Int       @default(0)
  failedCount    Int       @default(0)

  /// JSON array de { email, name?, status: "sent"|"failed" } вЂ” salvo no envio
  recipientsJson String?   @db.Text

  /// Follow-up automГЎtico: data do Гєltimo envio
  followupSentAt    DateTime?
  /// NГєmero de follow-ups enviados
  followupCount     Int       @default(0)
  /// Assunto do follow-up (gerado automaticamente se null)
  followupSubject   String?
  /// JSON array de destinatГЎrios do follow-up (mesmo formato de recipientsJson)
  followupRecipientsJson String? @db.Text

  @@index([status])
  @@index([createdAt])
  @@index([followupSentAt])
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// AGENDAMENTO DE E-MAIL EM LOTES (WARMUP)
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Disparo gradual para aquecimento de domГ­nio de e-mail
model EmailBatchJob {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// AudiГЄncia alvo ("clientes" | "leads")
  audience    String   @default("clientes")

  /// ConteГєdo do e-mail
  subject     String
  body        String   @db.Text
  ctaText     String?
  ctaUrl      String?

  /// "active" | "paused" | "completed" | "cancelled"
  status      String   @default("active")

  totalTarget Int      @default(0)
  totalSent   Int      @default(0)

  /// JSON: Array<{ sendAt: string; batchSize: number; sent: boolean; sentAt?: string; sentCount?: number; failedCount?: number }>
  scheduleJson String  @db.Text

  @@index([status])
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// SESSГѓO WHATSAPP (BAILEYS)
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Guarda as credenciais de autenticaГ§ГЈo do WhatsApp Web em formato JSON para reconexГЈo via Baileys
model WhatsappSession {
  id        String   @id @default(cuid())
  phone     String   @unique
  data      String   @db.Text
  updatedAt DateTime @updatedAt
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// SISTEMA DE AUTOMAГ‡ГѓO (Motor prГіprio, sem n8n)
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Fluxo de automaГ§ГЈo вЂ” define gatilho + sequГЄncia de passos
model AutomationFlow {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  name          String
  description   String?
  active        Boolean         @default(true)

  /// SCHEDULE | WEBHOOK | EVENT
  triggerType   String
  /// SCHEDULE: {cron:"0 9 * * *"} | WEBHOOK: {token:"xyz"} | EVENT: {event:"payment_confirmed"}
  triggerConfig Json

  /// Array de passos: [{id, type, label, config}]
  steps         Json            @default("[]")

  runs          AutomationRun[]

  @@index([active])
  @@index([triggerType])
}

/// Registro de execuГ§ГЈo de um fluxo de automaГ§ГЈo
model AutomationRun {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())

  flowId      String
  flow        AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  /// pending | running | completed | failed
  status      String         @default("pending")

  /// Dados de entrada que dispararam este fluxo
  inputData   Json?

  /// Logs de cada passo: [{stepId, label, ok, message, ts}]
  logs        Json           @default("[]")

  error       String?        @db.Text
  completedAt DateTime?

  @@index([flowId])
  @@index([status])
  @@index([createdAt])
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// PRODUГ‡ГѓO / GESTГѓO (preГ§os, fornecedores, estoque)
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// CatГЎlogo dos modelos de sacola que vendemos (AlГ§a Camiseta, AlГ§a Vazada, AlГ§a Fita)
model Modelo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nome      String   @unique
  ativo     Boolean  @default(true)

  precos    TabelaPreco[]
  custos    FornecedorCusto[]
}

/// Tabela de valores (preГ§o de venda ao cliente) por modelo, tamanho e faixa de quantidade
model TabelaPreco {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// Mantido por compatibilidade (ex: "AlГ§a Camiseta 40x50") вЂ” a fonte de verdade agora Г© modeloId + tamanho
  tipo          String

  modeloId      String?
  modelo        Modelo?  @relation(fields: [modeloId], references: [id])
  /// Tamanho no formato "40x50"
  tamanho       String?

  qtdMin        Int
  qtdMax        Int?
  precoUnitario Float
  ativo         Boolean  @default(true)
  notas         String?

  @@index([tipo])
  @@index([ativo])
  @@index([modeloId])
}

/// Custo de compra (o que pagamos) por fornecedor + modelo + tamanho + cor. ReferГЄncia, nГЈo Г© preГ§o de venda nem estoque fГ­sico.
model FornecedorCusto {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  fornecedorId String
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)

  modeloId     String
  modelo       Modelo     @relation(fields: [modeloId], references: [id])

  /// Tamanho no formato "40x50"
  tamanho      String
  /// Cor ou faixa de cor (ex: "Branco/Preto", "Colorida", "Diversas cores")
  cor          String?
  /// Espessura/gramatura (ex: "0,05")
  gramatura    String?

  precoKgCents       Int
  pesoMilheiroKg     Float?
  custoMilheiroCents Int?
  qtdPacote          Int?

  notas        String?

  @@index([fornecedorId])
  @@index([modeloId])
}

/// Fornecedores de matГ©ria-prima (sacolas em branco, tintas, etc.)
model Fornecedor {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nome      String
  produto   String
  whatsapp  String?
  email     String?
  /// CNPJ do fornecedor (sem pontuaГ§ГЈo)
  cnpj      String?
  /// RazГЈo social/empresa
  razaoSocial String?
  /// EndereГ§o (rua e nГєmero)
  endereco  String?
  /// Bairro
  bairro    String?
  /// Cidade
  cidade    String?
  /// CEP
  cep       String?
  /// Estado (ex: SP)
  estado    String?
  /// Telefone fixo para contato
  telefone  String?
  /// Email adicional para contato
  emailAdicional String?
  /// Site do fornecedor
  site      String?
  /// Banco para depГіsitos (ex: "ItaГє S/A")
  banco1    String?
  /// AgГЄncia do primeiro banco
  agencia1  String?
  /// Conta corrente do primeiro banco
  conta1    String?
  /// Segundo banco (se houver)
  banco2    String?
  /// AgГЄncia do segundo banco
  agencia2  String?
  /// Conta corrente do segundo banco
  conta2    String?
  ativo     Boolean  @default(true)

  /// ReferГЄncia rГЎpida em texto livre вЂ” mantido para fornecedores sem dados estruturados ainda (ver FornecedorCusto)
  tabelaCustos String? @db.Text

  compras   Compra[]
  custos    FornecedorCusto[]

  @@index([ativo])
}

/// Controle de estoque de matГ©ria-prima
model Estoque {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  produto    String
  tipo       String
  /// Tamanho do item (ex: "40x50")
  tamanho    String?
  /// Gramatura/espessura (ex: "0,05")
  gramatura  String?
  /// Cor do item
  cor        String?
  /// Quantidade de unidades por pacote (ex: 500, 250)
  quantidadePacote Int?
  /// Quantidade em estoque
  quantidade Float @default(0)
  unidade    String   @default("un")
  minimo     Float    @default(0)
  /// PreГ§o por kg em centavos (ex: 2890 = R$ 28,90)
  precoKgCents Int?
  /// Custo aproximado por milheiro em centavos
  custoMilheiroCents Int?

  @@index([produto])
  @@index([tipo])
  @@index([tamanho])
  @@index([gramatura])
}

